---
import Layout from "../../layouts/Layout.astro";
import { areas, areaGroups } from "../../data/areas";

const pageTitle = "出張エリア一覧 | 髙橋遊月ピアノ教室";
const pageDescription =
    "髙橋遊月ピアノ教室の出張レッスン対応エリア一覧。清澄白河、豊洲、門前仲町、月島、勝どき、晴海、日本橋、茅場町、八丁堀、築地、新富町、佃、木場、人形町、水天宮前、浜町など江東区・中央区エリアに対応。大人の初心者・再開者・趣味のレッスンを中心に、通学不要の出張ピアノレッスンを承っています。";

// ItemList Schema for area index
const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "BreadcrumbList",
            itemListElement: [
                {
                    "@type": "ListItem",
                    position: 1,
                    item: {
                        "@id": Astro.site?.toString(),
                        name: "ホーム",
                    },
                },
                {
                    "@type": "ListItem",
                    position: 2,
                    item: {
                        "@id": new URL("/area", Astro.site).toString(),
                        name: "出張エリア",
                    },
                },
            ],
        },
        {
            "@type": "ItemList",
            name: "出張ピアノレッスン対応エリア一覧",
            description: pageDescription,
            numberOfItems: areas.length,
            itemListElement: areas.map((area, index) => ({
                "@type": "ListItem",
                position: index + 1,
                item: {
                    "@type": "Service",
                    name: `${area.name}の出張ピアノ教室`,
                    url: new URL(`/area/${area.slug}`, Astro.site).toString(),
                    description: area.catchphrase,
                },
            })),
        },
    ],
});
---

<Layout title={pageTitle} description={pageDescription}>
    <!-- Structured Data -->
    <script slot="head" type="application/ld+json" set:html={schema} />

    <div
        class="relative h-[40vh] flex items-center justify-center overflow-hidden bg-[#F3EFE9]"
    >
        <div class="relative z-10 text-center px-6 pt-10">
            <h1
                class="text-3xl md:text-5xl font-serif mb-4 tracking-wider text-[#544A40]"
            >
                出張エリア
            </h1>
            <div
                class="flex items-center justify-center gap-4 text-[#A88B58] text-xs md:text-sm tracking-[0.2em] font-serif uppercase"
            >
                <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                Area List
                <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
            </div>
        </div>
    </div>

    <section class="pt-12 pb-20 px-6 max-w-6xl mx-auto">
        <p
            class="text-[#544A40]/80 mb-12 max-w-2xl mx-auto leading-relaxed text-left md:text-center"
        >
            江東区・中央区・港区・千代田区・文京区・台東区・墨田区を中心に、<wbr />ご自宅や近隣スタジオへの出張ピアノレッスンを<wbr
            />承っております。<br class="hidden md:block" />
            各エリアの詳細ページでは、<wbr />地域に合わせたレッスンの<wbr
            />ご案内をしています。
        </p>

        {
            areaGroups.map((group) => (
                <div class="mb-12">
                    <h2 class="text-lg font-serif text-[#544A40] mb-6 border-l-4 border-[#A88B58] pl-4">
                        {group.label}
                        <span class="text-sm text-[#A88B58] ml-2 font-sans font-normal">
                            {group.district}
                        </span>
                    </h2>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        {group.areaSlugs.map((slug) => {
                            const area = areas.find((a) => a.slug === slug);
                            if (!area) return null;
                            return (
                                <a
                                    href={`/area/${area.slug}`}
                                    class="group block bg-white rounded-lg overflow-hidden shadow-md hover:shadow-xl transition-all duration-300 transform hover:-translate-y-1 h-full flex flex-col"
                                >
                                    <div class="relative h-48 overflow-hidden bg-gray-100 flex-shrink-0">
                                        <img
                                            src={area.mainImage}
                                            alt={area.mainImageAlt || area.name}
                                            class="w-full h-full object-cover transition-transform duration-500 scale-110 group-hover:scale-125 opacity-80 group-hover:opacity-100"
                                            loading="lazy"
                                        />
                                        <div class="absolute inset-0 bg-black/5 group-hover:bg-black/0 transition-colors" />
                                    </div>
                                    <div class="p-6 flex flex-col flex-grow">
                                        <h3 class="text-xl font-serif text-[#544A40] mb-2 group-hover:text-[#A88B58] transition-colors">
                                            {area.name}のピアノ教室
                                        </h3>
                                        <p class="text-sm text-[#544A40]/60 mb-4 line-clamp-2 flex-grow">
                                            {area.catchphrase.replace(/<[^>]*>/g, "")}
                                        </p>
                                        <div class="text-right text-xs text-[#A88B58] font-medium md:opacity-0 md:group-hover:opacity-100 transition-opacity">
                                            詳しく見る →
                                        </div>
                                    </div>
                                </a>
                            );
                        })}
                    </div>
                </div>
            ))
        }
    </section>

    <section class="bg-[#F3EFE9] py-20 px-6">
        <div class="max-w-4xl mx-auto text-center">
            <h2 class="text-2xl font-serif mb-6 text-[#544A40]">
                その他のエリアについても<br class="md:hidden" />ご相談ください
            </h2>
            <p
                class="mb-10 text-[#544A40]/80 leading-relaxed text-left md:text-center"
            >
                記載のないエリアでも、近隣であれば対応可能な場合がございます。<br
                    class="hidden md:block"
                />
                まずはお気軽にお問い合わせください。
            </p>
            <div class="flex flex-col sm:flex-row justify-center items-center gap-4 max-w-2xl mx-auto">
                <a
                    href="https://lin.ee/QL31tIZ"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center bg-[#06C755] hover:bg-[#05b04b] text-white font-bold py-4 px-8 rounded-full transition-all duration-300 tracking-wider shadow-md hover:shadow-lg transform hover:-translate-y-0.5 w-full sm:w-auto gap-2 line_click_area"
                >
                    <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22 10.02c0-4.428-4.486-8.02-10-8.02S2 5.592 2 10.02c0 3.966 3.23 7.284 7.6 7.907.296.064.697.195.797.447.091.229.06.588.029.842-.116.892-.375 2.564-.427 2.9-.06.398.146.365.309.244.152-.113 2.454-1.619 3.456-2.319.721.2 1.488.31 2.236.31 5.514 0 10-3.593 10-8.021z"/>
                    </svg>
                    公式LINEで相談する
                </a>
                <a
                    href="/contact#mail-form"
                    class="inline-flex items-center justify-center bg-white hover:bg-[#F7F3EE] text-[#544A40] border border-[#DCD3C7] font-bold py-4 px-8 rounded-full transition-all duration-300 tracking-wider shadow-md hover:shadow-lg transform hover:-translate-y-0.5 w-full sm:w-auto"
                >
                    メールフォームから相談する
                </a>
            </div>
        </div>
    </section>
</Layout>
