---
import InstructorProfile from "../common/InstructorProfile.astro";

const introduction = `東京音楽大学卒業。クラシックを基礎に、初心者の方の基礎づくりから、久しぶりにピアノを再開したい方、好きな曲を仕上げたい方まで、目的に合わせてレッスンを行っています。
クラシックだけでなく、ポップスや映画音楽、伴奏曲のご相談にも対応しています。
出張形式のため通学の手間がなく、ご自宅や近隣スタジオでそのまま受講できます。仕事や家事の予定がある方でも、生活リズムに合わせた受講頻度や練習方法を一緒に相談しながら進めます。`;
---

<section id="profile" class="py-24 bg-white">
    <div class="max-w-5xl mx-auto px-6">
        <div class="text-center mb-16">
            <h2 class="text-2xl md:text-3xl font-serif mb-4">講師紹介</h2>
            <div
                class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase"
            >
                <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                Profile
                <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
            </div>
        </div>
        <InstructorProfile introduction={introduction} />
    </div>
</section>
