---
import { Image } from "astro:assets";
import heroPiano from "../../assets/images/hero-piano.webp";
---

<section
    class="relative h-[100svh] w-full flex items-center justify-center overflow-hidden"
>
    <div class="absolute inset-0 z-0 bg-[#1A130E]">
        <Image
            src={heroPiano}
            alt="落ち着いた空間でのピアノレッスン"
            width={800}
            height={1200}
            class="w-full h-full object-cover opacity-60 object-[35%_center]"
            loading="eager"
            fetchpriority="high"
        />
        {/* 上下のグラデーションでテキストを読みやすく */}
        <div class="absolute inset-0 bg-gradient-to-t from-[#1A130E] via-transparent to-[#1A130E]/60"></div>
    </div>

    <div class="relative z-10 w-full h-full p-8 pt-28 pb-32 flex flex-col justify-between">
        {/* 左上：英語の装飾的テキスト */}
        <div class="self-start">
            <span class="block text-[#E8E2D9]/90 font-sans text-xs tracking-[0.3em] uppercase mb-1 drop-shadow-md">Piano Lesson</span>
            <span class="block text-[#E8E2D9]/60 font-sans text-[10px] tracking-[0.2em] uppercase">Tokyo Area</span>
        </div>

        {/* 右下：縦書きの印象的な日本語キャッチコピー */}
        <div class="self-end flex gap-6 h-full items-end justify-end pb-8">
            <h1 class="flex gap-4 items-start" style="writing-mode: vertical-rl;">
                <span class="block text-[28px] tracking-[0.4em] text-white font-serif drop-shadow-xl leading-loose">
                    髙橋遊月ピアノ教室
                </span>
                <span class="block text-[15px] tracking-[0.4em] text-[#E8E2D9] font-serif mt-4 drop-shadow-lg leading-loose">
                    大人のための出張レッスン
                </span>
            </h1>
        </div>

        {/* 画面下部：バッジとスクロールインジケーター */}
        <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-4 w-full">
            <span
                class="inline-block px-8 py-2.5 border border-white/30 rounded-full text-[10px] tracking-[0.25em] backdrop-blur-md bg-white/5 text-white font-medium font-serif shadow-sm"
            >
                出張・スタジオ対応
            </span>
            <div class="w-[1px] h-10 bg-white/30 relative overflow-hidden">
                <div class="absolute top-0 left-0 w-full h-full bg-white animate-[scroll_2s_ease-in-out_infinite]"></div>
            </div>
        </div>
    </div>
</section>

<style>
    @keyframes scroll {
        0% { transform: translateY(-100%); }
        100% { transform: translateY(100%); }
    }
</style>
