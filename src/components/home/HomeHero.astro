---
import { Image } from "astro:assets";
import heroPiano from "../../assets/images/hero-piano.webp";
---

<section
    class="relative h-[100svh] md:h-[65vh] md:min-h-[600px] w-full flex items-center justify-center overflow-hidden"
>
    {/* =========================================
        スマホ表示用（md:hidden）
       ========================================= */}
    <div class="md:hidden absolute inset-0 z-0 bg-[#1A130E]">
        <Image
            src={heroPiano}
            alt="落ち着いた空間でのピアノレッスン"
            width={800}
            height={1200}
            class="w-full h-full object-cover opacity-60 object-[35%_center]"
            loading="eager"
            fetchpriority="high"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-[#1A130E] via-transparent to-[#1A130E]/60"></div>
    </div>

    <div class="md:hidden relative z-10 w-full h-full p-8 pt-6 pb-32 flex flex-col justify-between">
        <div class="self-start">
            <span class="block text-[#E8E2D9]/90 font-sans text-xs tracking-[0.3em] uppercase mb-1 drop-shadow-md">Piano Lesson</span>
            <span class="block text-[#E8E2D9]/60 font-sans text-[10px] tracking-[0.2em] uppercase">Tokyo Area</span>
        </div>

        <div class="self-center flex h-full items-end pb-24 -translate-x-6">
            <h1 class="flex flex-col gap-8 items-end" style="writing-mode: vertical-rl;">
                <span class="block text-[28px] tracking-[0.5em] text-white font-serif drop-shadow-xl leading-loose">
                    髙橋遊月ピアノ教室
                </span>
                <span class="block text-[17px] tracking-[0.4em] text-[#E8E2D9]/85 font-serif font-medium drop-shadow-lg leading-loose translate-y-4">
                    大人の出張ピアノレッスン
                </span>
            </h1>
        </div>

        <div class="absolute bottom-12 left-1/2 -translate-x-1/2 flex flex-col items-center gap-4 w-full">
            <span
                class="inline-block px-8 py-2.5 border border-white/30 rounded-none text-[10px] tracking-[0.25em] backdrop-blur-md bg-white/5 text-white font-medium font-serif shadow-sm"
            >
                出張・スタジオ対応
            </span>
        </div>
    </div>

    {/* =========================================
        PC表示用（hidden md:flex/block）
       ========================================= */}
    <div class="hidden md:block absolute inset-0 z-0 bg-[#1A130E]">
        <Image
            src={heroPiano}
            alt="落ち着いた空間でのピアノレッスン"
            width={1200}
            height={800}
            class="w-full h-full object-cover opacity-50 object-[25%_center]"
            loading="lazy"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-[#1A130E]/80 via-[#1A130E]/70 to-[#1A130E]/85"></div>
    </div>

    <div class="hidden md:flex relative z-10 text-center px-4 w-full max-w-4xl mx-auto flex-col items-center">
        <span class="block text-sm tracking-[0.2em] leading-relaxed mb-6 text-[#D4C5B9] font-serif font-medium uppercase">
            <span class="inline-block">東京都内</span><span class="inline-block">（江東区・中央区周辺）</span><span class="inline-block">出張・スタジオ対応</span>
        </span>

        <h1 class="font-serif text-white/95 flex flex-col items-center">
            <span class="text-xl tracking-[0.2em] text-[#E8E2D9] font-medium mb-4">大人のための出張ピアノレッスン</span>
            <span class="block text-5xl lg:text-6xl font-medium tracking-[0.08em] mb-8 leading-tight text-white drop-shadow-lg">
                髙橋遊月ピアノ教室
            </span>
        </h1>

        <p class="font-serif text-base leading-[2.8] tracking-widest text-white/90 max-w-3xl mx-auto font-medium animate-fade-in">
            ご自宅や近隣スタジオでのマンツーマン出張レッスン。<br />
            初めての方からブランクのある方まで、ご希望のペースや曲に合わせて丁寧に進めます。
        </p>
    </div>
</section>

<style>
    @keyframes scroll {
        0% { transform: translateY(-100%); }
        100% { transform: translateY(100%); }
    }
</style>
