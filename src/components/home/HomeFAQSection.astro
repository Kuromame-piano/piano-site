---
const faqs = [
    {
        q: "大人の初心者で、楽譜も読めませんが大丈夫でしょうか？",
        a: "はい。楽譜の読み方や指の動かし方など、基礎から順を追って確認します。大人になってからピアノに初めて触れる方にも対応しています。",
    },
    {
        q: "昔少し習っていた程度でブランクが長いのですが、再開できますか？",
        a: "はい。以前の経験やブランクの長さに関わらず、現在の状態を確認しながら進めます。弾きたい曲を軸に、必要な部分を整理する進め方も相談できます。",
    },
    {
        q: "好きな曲や映画音楽、特定の課題曲だけを見てもらうことはできますか？",
        a: "はい。クラシックに限らず、ポップス、映画音楽、合唱の伴奏曲など、弾きたい曲や苦手な部分をピンポイントで見てほしいというご要望にも対応しています。",
    },
    {
        q: "自宅に講師を呼ぶスペースがないのですが、スタジオでも可能ですか？",
        a: "はい。ご自宅への訪問が難しい場合は、近隣のレンタルスタジオでのレッスンもご相談いただけます（別途会場費がかかります）。仕事帰りや外出ついでにスタジオを利用されている方もいます。",
    },
    {
        q: "忙しくて毎週通えないのですが、月1回だけでも受講できますか？",
        a: "はい。月ごとにレッスン日時を相談して決める形でも対応しています。固定曜日にこだわらず、予定に合わせて都度調整することもできます。",
    },
];
---

<section class="py-20 bg-[#FCFAF7] border-t border-[#F1EBE4]">
    <div class="max-w-4xl mx-auto px-6">
        <div class="text-center mb-16">
            <h2 class="text-2xl md:text-3xl font-serif mb-4 text-[#544A40]">
                よくあるご質問
            </h2>
            <div
                class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase"
            >
                <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                FAQ
                <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
            </div>
        </div>

        <div class="space-y-4 max-w-3xl mx-auto">
            {
                faqs.map((faq) => (
                    <details class="group bg-white rounded-xl shadow-sm border border-[#F1EBE4] overflow-hidden">
                        <summary class="flex items-center justify-between p-6 cursor-pointer list-none hover:bg-[#FCFAF7]/50 transition-colors">
                            <span class="font-bold font-serif text-[#544A40] pr-4 text-left text-sm md:text-base">
                                <span class="text-[#A88B58] mr-2">Q.</span>
                                {faq.q}
                            </span>
                            <span class="flex-shrink-0 w-6 h-6 flex items-center justify-center text-[#A88B58] transition-transform group-open:rotate-180">
                                <svg
                                    xmlns="http://www.w3.org/2000/svg"
                                    fill="none"
                                    viewBox="0 0 24 24"
                                    stroke-width="2"
                                    stroke="currentColor"
                                    class="w-5 h-5"
                                >
                                    <path
                                        stroke-linecap="round"
                                        stroke-linejoin="round"
                                        d="M19.5 8.25l-7.5 7.5-7.5-7.5"
                                    />
                                </svg>
                            </span>
                        </summary>
                        <div class="px-6 pb-6 text-sm leading-loose text-[#6B5F54] border-t border-[#F1EBE4]">
                            <div class="pt-4 flex items-start gap-2">
                                <span class="text-[#A88B58] font-bold flex-shrink-0">A.</span>
                                <span>{faq.a}</span>
                            </div>
                        </div>
                    </details>
                ))
            }
        </div>

        <div class="mt-12 text-center">
            <a
                href="/faq"
                class="inline-block border border-[#A88B58] text-[#A88B58] px-10 py-3 rounded-full hover:bg-[#A88B58] hover:text-white transition-all text-sm tracking-widest font-medium"
            >
                よくある質問一覧を見る →
            </a>
        </div>
    </div>
</section>

<style>
    details summary::-webkit-details-marker {
        display: none;
    }
</style>
