---
import type { Area } from "../../data/areas";

interface Props {
    area: Area;
    variant?: "mid" | "final";
}

const { area, variant = "final" } = Astro.props;
const ctaHref = `/contact?from=${encodeURIComponent(`area-${area.slug}`)}&area=${encodeURIComponent(area.name)}#mail-form`;
const isMid = variant === "mid";
---

<section
    class={`py-20 px-6 ${isMid ? "bg-[#EAE3DA] text-[#544A40]" : "bg-[#544A40] text-white"}`}
>
    <div class="max-w-4xl mx-auto text-center">
        <div class="mb-10">
            <h2 class="text-2xl md:text-3xl font-serif mb-4">
                {
                    isMid
                        ? "体験レッスンはこちらから"
                        : "まずは無料体験レッスンから"
                }
            </h2>
            <div
                class={`flex items-center justify-center gap-4 text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase ${isMid ? "text-[#A88B58]" : "text-[#D4C5B0]"}`}
            >
                <div class={`h-[1px] w-8 ${isMid ? "bg-[#A88B58]/30" : "bg-[#D4C5B0]/30"}`}></div>
                Free Trial Lesson
                <div class={`h-[1px] w-8 ${isMid ? "bg-[#A88B58]/30" : "bg-[#D4C5B0]/30"}`}></div>
            </div>
        </div>
        <p class="mb-10 text-lg opacity-90 leading-relaxed">
            <span class="inline-block">{area.name}でピアノ教室を</span><span
                class="inline-block">お探しの方へ。</span
            ><br class="hidden md:block" /><span class="inline-block"
                >ご自宅でのレッスンが合うか、</span
            ><span class="inline-block">まずは無料体験で確認できます。</span><br class="hidden md:block" /><span class="inline-block"
                >楽器の種類や曜日・時間帯の</span
            ><span class="inline-block">相談だけでも大丈夫です。</span>
        </p>

        <div class="flex flex-col sm:flex-row justify-center items-center gap-4 max-w-2xl mx-auto">
            <a
                href="https://lin.ee/QL31tIZ"
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center bg-[#06C755] hover:bg-[#05b04b] text-white font-bold py-4.5 px-8 rounded-full transition-all duration-300 tracking-wider shadow-md hover:shadow-lg transform hover:-translate-y-0.5 w-full sm:w-auto gap-2 line_click_area_cta"
            >
                <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current" xmlns="http://www.w3.org/2000/svg">
                    <path d="M22 10.02c0-4.428-4.486-8.02-10-8.02S2 5.592 2 10.02c0 3.966 3.23 7.284 7.6 7.907.296.064.697.195.797.447.091.229.06.588.029.842-.116.892-.375 2.564-.427 2.9-.06.398.146.365.309.244.152-.113 2.454-1.619 3.456-2.319.721.2 1.488.31 2.236.31 5.514 0 10-3.593 10-8.021z"/>
                </svg>
                公式LINEで相談する
            </a>
            <a
                href={ctaHref}
                class={`inline-flex items-center justify-center font-bold py-4.5 px-8 rounded-full transition-all duration-300 tracking-wider shadow-md hover:shadow-lg transform hover:-translate-y-0.5 w-full sm:w-auto ${isMid ? "bg-[#544A40] hover:bg-[#3D352E] text-white" : "bg-white hover:bg-[#F7F3EE] text-[#544A40]"}`}
            >
                メールフォームから相談する
            </a>
        </div>
        <p class="mt-6 text-xs opacity-70 tracking-wider">
            ※ まだ入会を決めていない段階でも、お気軽にご相談いただけます。
        </p>
    </div>
</section>
