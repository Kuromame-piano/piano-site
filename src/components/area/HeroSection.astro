---
import type { Area } from "../../data/areas";

interface Props {
    area: Area;
    objectPositionMobile?: string;
    objectPositionDesktop?: string;
    objectPosition?: string;
}

const { 
    area, 
    objectPositionMobile = "30% 35%", 
    objectPositionDesktop = "35% 35%", 
    objectPosition 
} = Astro.props;

const mobilePos = objectPosition || objectPositionMobile;
const desktopPos = objectPosition || objectPositionDesktop;
---

<div
    class="relative h-[100svh] md:h-[55vh] flex items-center justify-center overflow-hidden"
>
    {/* =========================================
        スマホ表示用（md:hidden）
       ========================================= */}
    <div class="md:hidden absolute inset-0 z-0 bg-[#1A130E]">
        <img
            src={area.mainImage}
            alt={area.mainImageAlt || `${area.name}の街並み`}
            class="w-full h-full object-cover opacity-60"
            style={`object-position: ${mobilePos}`}
        />
        <div class="absolute inset-0 bg-gradient-to-t from-[#1A130E] via-transparent to-[#1A130E]/60"></div>
    </div>

    <div class="md:hidden relative z-10 w-full h-full p-8 pt-6 pb-32 flex flex-col justify-between">
        <div class="self-start">
            <span class="block text-[#E8E2D9]/90 font-sans text-xs tracking-[0.3em] uppercase mb-1 drop-shadow-md">Piano Lesson</span>
            <span class="block text-[#E8E2D9]/60 font-sans text-[10px] tracking-[0.2em] uppercase">{area.name.toUpperCase()} Area</span>
        </div>

        <div id="mobile-title-container" class="self-center flex gap-4 h-full items-end pb-12 -translate-x-[26px]">
            <h1 class="flex flex-col gap-3 items-end" style="writing-mode: vertical-rl;">
                <span id="mobile-text-main" class="block text-[28px] tracking-[0.5em] text-white font-serif drop-shadow-xl leading-loose whitespace-nowrap">
                    髙橋遊月ピアノ教室
                </span>
                <span id="mobile-text-sub1" class="block text-[16px] tracking-[0.3em] text-[#F3EFEA] font-serif font-medium drop-shadow-lg leading-loose whitespace-nowrap">
                    {area.name}の大人向けピアノ教室
                </span>
                <span id="mobile-text-sub2" class="block text-[12px] tracking-[0.2em] text-[#E8E2D9]/90 font-serif drop-shadow-md leading-loose whitespace-nowrap">
                    自宅・近隣スタジオで受けられる出張レッスン
                </span>
            </h1>
        </div>

        <div id="mobile-badge-container" class="absolute bottom-32 left-1/2 -translate-x-1/2 flex flex-col items-center gap-4 w-full">
            <span
                id="mobile-badge"
                class="flex items-center justify-center w-[164px] h-[36px] border border-white/30 rounded-none text-[12px] tracking-[0.15em] backdrop-blur-md bg-white/5 text-[#E8E2D9] font-medium font-serif shadow-sm"
            >
                出張レッスン専門
            </span>
        </div>
    </div>

    {/* =========================================
        PC表示用（hidden md:flex）
       ========================================= */}
    <div class="hidden md:block absolute inset-0 z-0 bg-[#1A130E]">
        <img
            src={area.mainImage}
            alt={area.mainImageAlt || `${area.name}の街並み`}
            class="w-full h-full object-cover opacity-65 md:opacity-55"
            style={`object-position: ${desktopPos}`}
        />
        <div
            class="absolute inset-0 bg-gradient-to-b from-[#1A130E]/90 via-[#1A130E]/85 to-[#1A130E]/80 md:from-[#1A130E]/80 md:via-[#1A130E]/70 md:to-[#1A130E]/60"
        ></div>
    </div>

    <div
        class="hidden md:flex relative z-10 text-center text-white px-4 md:px-6 w-full max-w-4xl mx-auto flex-col items-center"
    >
        <h1 class="font-serif tracking-wide">
            <span
                class="block text-sm sm:text-base md:text-lg lg:text-xl mb-6 font-normal tracking-[0.05em] text-[#E8E2D9] drop-shadow-md max-w-2xl mx-auto leading-relaxed"
            >
                {area.name}の大人向けピアノ教室<br />自宅・近隣スタジオで受けられる出張レッスン
            </span>

            <span
                class="block text-2xl sm:text-4xl md:text-5xl lg:text-6xl font-medium tracking-[0.08em] mb-4 md:mb-8 leading-tight text-white drop-shadow-lg"
            >
                髙橋遊月ピアノ教室
            </span>
        </h1>

        <div class="mt-6">
            <span
                class="inline-block px-6 py-2 md:px-8 md:py-2.5 border border-white/30 rounded-none text-sm md:text-base tracking-[0.15em] backdrop-blur-sm bg-white/10 text-[#E8E2D9] font-medium font-serif"
            >
                出張レッスン専門
            </span>
        </div>
    </div>
</div>

<style>
    @keyframes scroll {
        0% { transform: translateY(-100%); }
        100% { transform: translateY(100%); }
    }

    /* スマホ表示用調整スタイル */
    #mobile-title-container {
        transform: translateX(-25px);
        padding-bottom: 150px;
    }
    #mobile-text-main {
        font-size: 32px;
    }
    #mobile-text-sub1 {
        font-size: 20px;
    }
    #mobile-text-sub2 {
        font-size: 16px;
    }
    #mobile-badge-container {
        bottom: 200px;
    }
    #mobile-badge {
        font-size: 12px;
    }
</style>

{import.meta.env.DEV && (
  <div id="bg-tuner-widget" class="fixed bottom-4 right-4 z-50 bg-[#1A130E]/90 border border-white/20 text-[#E8E2D9] p-4 font-sans text-xs shadow-2xl w-[320px] backdrop-blur-md rounded-lg">
    <div class="flex justify-between items-center mb-3 border-b border-white/10 pb-2">
      <span class="font-bold tracking-wider">背景・レイアウト調整 (DEV限定)</span>
      <button id="bg-tuner-toggle" class="text-white/60 hover:text-white text-[10px] uppercase tracking-wider">最小化</button>
    </div>
    
    <div id="bg-tuner-controls" class="space-y-4">
      {/* タブ切り替え */}
      <div class="flex border-b border-white/10 mb-3 text-[10px]">
        <button id="tab-bg" class="flex-1 pb-1.5 border-b-2 border-[#A88B58] text-white font-bold uppercase tracking-wider text-center">背景調整</button>
        <button id="tab-layout" class="flex-1 pb-1.5 border-b-2 border-transparent text-white/60 hover:text-white uppercase tracking-wider text-center">レイアウト(スマホ)</button>
      </div>

      {/* 背景調整コンテンツ */}
      <div id="content-bg" class="space-y-4">
        <div class="flex gap-2">
          <button id="btn-mode-mobile" class="flex-1 py-1.5 px-2 bg-white/10 text-white border border-white/20 font-medium rounded text-center">Mobile 用</button>
          <button id="btn-mode-desktop" class="flex-1 py-1.5 px-2 bg-transparent text-white/60 border border-transparent rounded text-center">Desktop 用</button>
        </div>

        <div class="space-y-2">
          <div class="flex justify-between">
            <span>左右位置 (X軸):</span>
            <span id="val-x" class="font-mono text-white">30%</span>
          </div>
          <input id="slider-x" type="range" min="0" max="100" value="30" class="w-full accent-[#A88B58] bg-white/10 h-1 rounded-lg appearance-none cursor-pointer" />
        </div>

        <div class="space-y-2">
          <div class="flex justify-between">
            <span>上下位置 (Y軸):</span>
            <span id="val-y" class="font-mono text-white">35%</span>
          </div>
          <input id="slider-y" type="range" min="0" max="100" value="35" class="w-full accent-[#A88B58] bg-white/10 h-1 rounded-lg appearance-none cursor-pointer" />
        </div>

        <div class="pt-2 border-t border-white/10 space-y-2">
          <button id="btn-copy-code" class="w-full py-2 bg-[#A88B58] hover:bg-[#8e7345] text-white font-bold rounded transition-colors text-center">
            画像コードをコピー
          </button>
          <div id="copy-status" class="text-[10px] text-center text-green-400 hidden">コピーしました！areas.ts に貼り付けてください。</div>
        </div>
      </div>

      {/* レイアウト(スマホ)調整コンテンツ */}
      <div id="content-layout" class="space-y-3 hidden max-h-[300px] overflow-y-auto pr-1">
        {/* 全体X位置 */}
        <div class="space-y-1">
          <div class="flex justify-between text-[10px]">
            <span>タイトル全体左右位置:</span>
            <span id="val-title-x" class="font-mono text-white">-25px</span>
          </div>
          <input id="slider-title-x" type="range" min="-80" max="80" value="-25" class="w-full accent-[#A88B58] bg-white/10 h-1 rounded-lg appearance-none cursor-pointer" />
        </div>

        {/* 全体Y位置 */}
        <div class="space-y-1">
          <div class="flex justify-between text-[10px]">
            <span>タイトル全体下部余白 (Y):</span>
            <span id="val-title-y" class="font-mono text-white">150px</span>
          </div>
          <input id="slider-title-y" type="range" min="0" max="250" value="150" class="w-full accent-[#A88B58] bg-white/10 h-1 rounded-lg appearance-none cursor-pointer" />
        </div>

        {/* メインタイトルサイズ */}
        <div class="space-y-1">
          <div class="flex justify-between text-[10px]">
            <span>髙橋遊月 文字サイズ:</span>
            <span id="val-font-main" class="font-mono text-white">32px</span>
          </div>
          <input id="slider-font-main" type="range" min="16" max="40" value="32" class="w-full accent-[#A88B58] bg-white/10 h-1 rounded-lg appearance-none cursor-pointer" />
        </div>

        {/* サブタイトル1サイズ */}
        <div class="space-y-1">
          <div class="flex justify-between text-[10px]">
            <span>大人向けピアノ 文字サイズ:</span>
            <span id="val-font-sub1" class="font-mono text-white">20px</span>
          </div>
          <input id="slider-font-sub1" type="range" min="12" max="24" value="20" class="w-full accent-[#A88B58] bg-white/10 h-1 rounded-lg appearance-none cursor-pointer" />
        </div>

        {/* サブタイトル2サイズ */}
        <div class="space-y-1">
          <div class="flex justify-between text-[10px]">
            <span>自宅スタジオ 文字サイズ:</span>
            <span id="val-font-sub2" class="font-mono text-white">16px</span>
          </div>
          <input id="slider-font-sub2" type="range" min="8" max="20" value="16" class="w-full accent-[#A88B58] bg-white/10 h-1 rounded-lg appearance-none cursor-pointer" />
        </div>

        {/* バッジ文字サイズ */}
        <div class="space-y-1">
          <div class="flex justify-between text-[10px]">
            <span>出張レッスン専門 文字サイズ:</span>
            <span id="val-font-badge" class="font-mono text-white">12px</span>
          </div>
          <input id="slider-font-badge" type="range" min="8" max="20" value="12" class="w-full accent-[#A88B58] bg-white/10 h-1 rounded-lg appearance-none cursor-pointer" />
        </div>

        {/* バッジ位置 */}
        <div class="space-y-1">
          <div class="flex justify-between text-[10px]">
            <span>バッジ下部位置:</span>
            <span id="val-badge-y" class="font-mono text-white">200px</span>
          </div>
          <input id="slider-badge-y" type="range" min="40" max="250" value="200" class="w-full accent-[#A88B58] bg-white/10 h-1 rounded-lg appearance-none cursor-pointer" />
        </div>

        <div class="pt-2 border-t border-white/10 space-y-2">
          <button id="btn-copy-layout" class="w-full py-2 bg-[#A88B58] hover:bg-[#8e7345] text-white font-bold rounded transition-colors text-center text-[10px]">
            CSSをコピー
          </button>
          <div id="layout-copy-status" class="text-[10px] text-center text-green-400 hidden">コピーしました！</div>
        </div>
      </div>
    </div>
  </div>

  <script is:inline define:vars={{ initialMobilePos: mobilePos, initialDesktopPos: desktopPos }}>
    const widget = document.getElementById('bg-tuner-widget');
    const controls = document.getElementById('bg-tuner-controls');
    const toggleBtn = document.getElementById('bg-tuner-toggle');
    
    // タブ切り替え
    const tabBg = document.getElementById('tab-bg');
    const tabLayout = document.getElementById('tab-layout');
    const contentBg = document.getElementById('content-bg');
    const contentLayout = document.getElementById('content-layout');

    tabBg.addEventListener('click', () => {
      tabBg.className = "flex-1 pb-1.5 border-b-2 border-[#A88B58] text-white font-bold uppercase tracking-wider text-center cursor-pointer";
      tabLayout.className = "flex-1 pb-1.5 border-b-2 border-transparent text-white/60 hover:text-white uppercase tracking-wider text-center cursor-pointer";
      contentBg.classList.remove('hidden');
      contentLayout.classList.add('hidden');
    });

    tabLayout.addEventListener('click', () => {
      tabLayout.className = "flex-1 pb-1.5 border-b-2 border-[#A88B58] text-white font-bold uppercase tracking-wider text-center cursor-pointer";
      tabBg.className = "flex-1 pb-1.5 border-b-2 border-transparent text-white/60 hover:text-white uppercase tracking-wider text-center cursor-pointer";
      contentLayout.classList.remove('hidden');
      contentBg.classList.add('hidden');
    });

    // 最小化・展開
    toggleBtn.addEventListener('click', () => {
      if (controls.classList.contains('hidden')) {
        controls.classList.remove('hidden');
        toggleBtn.textContent = '最小化';
      } else {
        controls.classList.add('hidden');
        toggleBtn.textContent = '展開';
      }
    });

    // === 背景画像調整 ===
    const btnMobile = document.getElementById('btn-mode-mobile');
    const btnDesktop = document.getElementById('btn-mode-desktop');
    const sliderX = document.getElementById('slider-x');
    const sliderY = document.getElementById('slider-y');
    const valX = document.getElementById('val-x');
    const valY = document.getElementById('val-y');
    const btnCopyBg = document.getElementById('btn-copy-code');
    const copyStatusBg = document.getElementById('copy-status');

    let activeMode = 'mobile';
    const parsePos = (posStr) => {
      const parts = posStr.split(' ');
      return { x: parseInt(parts[0]) || 50, y: parseInt(parts[1]) || 50 };
    };
    const mobilePosObj = parsePos(initialMobilePos);
    const desktopPosObj = parsePos(initialDesktopPos);
    const mobileImg = document.querySelector('.md\\:hidden img');
    const desktopImg = document.querySelector('.hidden.md\\:block img');

    const updateBgUI = () => {
      const current = activeMode === 'mobile' ? mobilePosObj : desktopPosObj;
      sliderX.value = current.x;
      sliderY.value = current.y;
      valX.textContent = `${current.x}%`;
      valY.textContent = `${current.y}%`;

      if (activeMode === 'mobile') {
        btnMobile.className = "flex-1 py-1.5 px-2 bg-white/10 text-white border border-white/20 font-medium rounded text-center cursor-pointer";
        btnDesktop.className = "flex-1 py-1.5 px-2 bg-transparent text-white/60 border border-transparent rounded text-center cursor-pointer";
      } else {
        btnMobile.className = "flex-1 py-1.5 px-2 bg-transparent text-white/60 border border-transparent rounded text-center cursor-pointer";
        btnDesktop.className = "flex-1 py-1.5 px-2 bg-white/10 text-white border border-white/20 font-medium rounded text-center cursor-pointer";
      }
    };

    const applyBgPosition = () => {
      const current = activeMode === 'mobile' ? mobilePosObj : desktopPosObj;
      const posStr = `${current.x}% ${current.y}%`;
      if (activeMode === 'mobile' && mobileImg) {
        mobileImg.style.objectPosition = posStr;
      } else if (activeMode === 'desktop' && desktopImg) {
        desktopImg.style.objectPosition = posStr;
      }
    };

    btnMobile.addEventListener('click', () => { activeMode = 'mobile'; updateBgUI(); });
    btnDesktop.addEventListener('click', () => { activeMode = 'desktop'; updateBgUI(); });

    const handleBgSlider = () => {
      const current = activeMode === 'mobile' ? mobilePosObj : desktopPosObj;
      current.x = parseInt(sliderX.value);
      current.y = parseInt(sliderY.value);
      valX.textContent = `${current.x}%`;
      valY.textContent = `${current.y}%`;
      applyBgPosition();
    };
    sliderX.addEventListener('input', handleBgSlider);
    sliderY.addEventListener('input', handleBgSlider);

    btnCopyBg.addEventListener('click', () => {
      const current = activeMode === 'mobile' ? mobilePosObj : desktopPosObj;
      const propName = activeMode === 'mobile' ? 'objectPositionMobile' : 'objectPositionDesktop';
      const code = `${propName}: "${current.x}% ${current.y}%",`;
      navigator.clipboard.writeText(code).then(() => {
        copyStatusBg.classList.remove('hidden');
        setTimeout(() => copyStatusBg.classList.add('hidden'), 3000);
      });
    });

    // === モバイルレイアウト調整 ===
    const titleContainer = document.getElementById('mobile-title-container');
    const textMain = document.getElementById('mobile-text-main');
    const textSub1 = document.getElementById('mobile-text-sub1');
    const textSub2 = document.getElementById('mobile-text-sub2');
    const badgeContainer = document.getElementById('mobile-badge-container');
    const badgeText = document.getElementById('mobile-badge');

    const sliderTitleX = document.getElementById('slider-title-x');
    const sliderTitleY = document.getElementById('slider-title-y');
    const sliderFontMain = document.getElementById('slider-font-main');
    const sliderFontSub1 = document.getElementById('slider-font-sub1');
    const sliderFontSub2 = document.getElementById('slider-font-sub2');
    const sliderFontBadge = document.getElementById('slider-font-badge');
    const sliderBadgeY = document.getElementById('slider-badge-y');

    const valTitleX = document.getElementById('val-title-x');
    const valTitleY = document.getElementById('val-title-y');
    const valFontMain = document.getElementById('val-font-main');
    const valFontSub1 = document.getElementById('val-font-sub1');
    const valFontSub2 = document.getElementById('val-font-sub2');
    const valFontBadge = document.getElementById('val-font-badge');
    const valBadgeY = document.getElementById('val-badge-y');

    const btnCopyLayout = document.getElementById('btn-copy-layout');
    const copyStatusLayout = document.getElementById('layout-copy-status');

    const applyLayout = () => {
      if (titleContainer) {
        titleContainer.style.transform = `translateX(${sliderTitleX.value}px)`;
        titleContainer.style.paddingBottom = `${sliderTitleY.value}px`;
      }
      if (textMain) textMain.style.fontSize = `${sliderFontMain.value}px`;
      if (textSub1) textSub1.style.fontSize = `${sliderFontSub1.value}px`;
      if (textSub2) textSub2.style.fontSize = `${sliderFontSub2.value}px`;
      if (badgeText) badgeText.style.fontSize = `${sliderFontBadge.value}px`;
      if (badgeContainer) badgeContainer.style.bottom = `${sliderBadgeY.value}px`;

      valTitleX.textContent = `${sliderTitleX.value}px`;
      valTitleY.textContent = `${sliderTitleY.value}px`;
      valFontMain.textContent = `${sliderFontMain.value}px`;
      valFontSub1.textContent = `${sliderFontSub1.value}px`;
      valFontSub2.textContent = `${sliderFontSub2.value}px`;
      valFontBadge.textContent = `${sliderFontBadge.value}px`;
      valBadgeY.textContent = `${sliderBadgeY.value}px`;
    };

    [sliderTitleX, sliderTitleY, sliderFontMain, sliderFontSub1, sliderFontSub2, sliderFontBadge, sliderBadgeY].forEach(slider => {
      slider.addEventListener('input', applyLayout);
    });

    btnCopyLayout.addEventListener('click', () => {
      const code = `/* スマホ表示用調整スタイル */
#mobile-title-container {
  transform: translateX(${sliderTitleX.value}px);
  padding-bottom: ${sliderTitleY.value}px;
}
#mobile-text-main {
  font-size: ${sliderFontMain.value}px;
}
#mobile-text-sub1 {
  font-size: ${sliderFontSub1.value}px;
}
#mobile-text-sub2 {
  font-size: ${sliderFontSub2.value}px;
}
#mobile-badge-container {
  bottom: ${sliderBadgeY.value}px;
}
#mobile-badge {
  font-size: ${sliderFontBadge.value}px;
}`;
      navigator.clipboard.writeText(code).then(() => {
        copyStatusLayout.classList.remove('hidden');
        setTimeout(() => copyStatusLayout.classList.add('hidden'), 3000);
      });
    });

    // 初期化
    updateBgUI();
    applyLayout();
  </script>
)}

