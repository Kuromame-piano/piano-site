---
import Layout from "../layouts/Layout.astro";
import LessonFlowSection from "../components/lesson/LessonFlowSection.astro";
import LessonPriceSection from "../components/lesson/LessonPriceSection.astro";
import LessonCTASection from "../components/lesson/LessonCTASection.astro";

const pageTitle =
    "ピアノ訪問・出張レッスンの流れ・料金 | 江東区・清澄白河 | 髙橋遊月ピアノ教室";
const pageDescription =
    "清澄白河発。大人向けの出張ピアノレッスンを行う「髙橋遊月ピアノ教室」のレッスンの流れ・料金のご案内。マンツーマンの個人指導で、通学不要のため仕事や家事の合間でも受講しやすいシステムです。";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
        {
            "@type": "ListItem",
            position: 1,
            name: "Home",
            item: "https://playon-music.jp",
        },
        {
            "@type": "ListItem",
            position: 2,
            name: "レッスンについて",
            item: "https://playon-music.jp/lesson",
        },
    ],
});
---

<Layout title={pageTitle} description={pageDescription}>
    <script type="application/ld+json" set:html={schema} slot="head" />

    <LessonFlowSection />
    <LessonPriceSection />
    <LessonCTASection />
</Layout>
