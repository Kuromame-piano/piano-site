---
import Layout from "../layouts/Layout.astro";
import FeeSystem from "../components/common/FeeSystem.astro";
import { areas } from "../data/areas";
import { Image } from "astro:assets";

const pageTitle = "大人の出張ピアノレッスン｜初心者・再開したい方も対応｜江東区・中央区周辺";
const pageDescription = "江東区・中央区周辺で大人向け出張ピアノレッスンを行っています。初心者、子どもの頃に習っていた方、好きな曲を弾きたい方も相談可能。月1回から、生活リズムに合わせて無理なく始められます。無料体験レッスン受付中です。";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Home",
                    "item": "https://playon-music.jp",
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "大人の出張ピアノレッスン",
                    "item": "https://playon-music.jp/adult-piano-lesson",
                },
            ],
        },
        {
            "@type": "Service",
            "name": "大人の出張ピアノレッスン",
            "provider": {
                "@type": "MusicSchool",
                "name": "髙橋遊月ピアノ教室",
                "url": "https://playon-music.jp",
                "image": "https://playon-music.jp/image.png",
            },
            "description": "江東区・中央区周辺で大人向け出張ピアノレッスンを行っています。初心者、子どもの頃に習っていた方、好きな曲を弾きたい方も相談可能。月1回から、生活リズムに合わせて無理なく始められます。",
            "url": "https://playon-music.jp/adult-piano-lesson"
        }
    ],
});

// Filter the specified areas from areas.ts
const targetAreaSlugs = [
    "kiyosumi-shirakawa", "monzen-nakacho", "kiba", "morishita", "sumiyoshi",
    "toyosu", "ariake", "shinonome", "tsukishima", "kachidoki", "harumi",
    "ningyocho", "suitengu-mae", "hamacho"
];

const adultAreas = areas.filter(a => targetAreaSlugs.includes(a.slug));
---

<Layout title={pageTitle} description={pageDescription}>
    <script type="application/ld+json" set:html={schema} slot="head" />

    {/* 1. Hero / First View */}
    <section class="relative bg-gradient-to-b from-[#F7F3EE] to-[#FCFAF7] py-20 md:py-28 overflow-hidden">
        <div class="max-w-6xl mx-auto px-6 relative z-10">
            <div class="grid lg:grid-cols-[55%_45%] gap-12 items-center">
                <div>
                    <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-xs font-bold tracking-[0.2em] px-4 py-1.5 rounded-full mb-6 font-serif uppercase">
                        Adult Piano Lesson
                    </span>
                    <h1 class="font-serif text-[#544A40] mb-6">
                        <span class="block text-xs sm:text-sm font-bold tracking-widest text-[#A88B58] mb-2 uppercase">江東区・中央区周辺の</span>
                        <span class="block text-2xl sm:text-3xl md:text-4xl lg:text-5xl leading-snug font-bold">
                            <span class="inline-block">大人向け</span><span class="inline-block">出張ピアノレッスン</span>
                        </span>
                    </h1>
                    <p class="text-sm sm:text-base md:text-lg text-[#A88B58] font-bold mb-6 font-serif">
                        初心者の方も、久しぶりに再開したい方も、自分のペースで始められます
                    </p>
                    <p class="text-sm md:text-base text-[#6B5F54] leading-loose mb-10">
                        初心者の方、子どもの頃に習っていて再開したい方、好きな曲を自分のペースで弾きたい方へ。<br />
                        ご自宅や近隣スタジオで、生活リズムに合わせて無理なく始められる大人のピアノレッスンです。
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 mb-6">
                        <a href="https://lin.ee/QL31tIZ" target="_blank" rel="noopener noreferrer" id="hero-cta-trial" class="inline-flex items-center justify-center bg-[#06C755] hover:bg-[#05b04b] text-white text-center font-bold px-4 sm:px-8 py-3.5 sm:py-4 rounded-full shadow-lg transition-all duration-300 transform hover:-translate-y-1 text-xs sm:text-sm tracking-wider whitespace-normal sm:whitespace-nowrap line_click_firstview gap-2">
                            <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current" xmlns="http://www.w3.org/2000/svg">
                                <path d="M22 10.02c0-4.428-4.486-8.02-10-8.02S2 5.592 2 10.02c0 3.966 3.23 7.284 7.6 7.907.296.064.697.195.797.447.091.229.06.588.029.842-.116.892-.375 2.564-.427 2.9-.06.398.146.365.309.244.152-.113 2.454-1.619 3.456-2.319.721.2 1.488.31 2.236.31 5.514 0 10-3.593 10-8.021z"/>
                            </svg>
                            公式LINEで大人の体験レッスンを相談する
                        </a>
                        <a href="#fees" id="hero-cta-consult" class="inline-flex items-center justify-center bg-white hover:bg-[#F7F3EE] text-[#544A40] border border-[#E8E2D9] text-center font-bold px-4 sm:px-8 py-3.5 sm:py-4 rounded-full shadow-lg transition-all duration-300 transform hover:-translate-y-1 text-xs sm:text-sm tracking-wider whitespace-nowrap">
                            料金を見る
                        </a>
                    </div>
                    <p class="text-xs text-[#6B5F54] tracking-wider leading-relaxed">
                        自宅で受けられるか、スタジオ利用がよいか、月1回でも大丈夫かなど、迷っている段階でも公式LINEからご相談いただけます。
                    </p>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="bg-white p-4 sm:p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">初心者歓迎</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">楽譜の読み方、指番号、姿勢など基礎から確認できます</p>
                    </div>

                    <div class="bg-white p-4 sm:p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">再開レッスン対応</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">ブランクがある方も、現在の状態を見ながら再開できます</p>
                    </div>

                    <div class="bg-white p-4 sm:p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">好きな曲も相談可</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">クラシック、ポップス、映画音楽など弾きたい曲をご相談ください</p>
                    </div>

                    <div class="bg-white p-4 sm:p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">月1回から相談可</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">空き枠やご希望に合わせて、月1回〜ご相談いただけます</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* 2. 大人のピアノでよくある不安 */}
    <section class="py-20 bg-white">
        <div class="max-w-5xl mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-2xl md:text-3xl font-serif text-[#544A40] mb-4">大人のピアノでよくある不安</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                    Common Worries
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                </div>
                <p class="text-sm text-[#6B5F54] leading-loose mt-6 max-w-2xl mx-auto">
                    大人になってからピアノを始めるときは、経験や年齢、練習時間のことが気になる方も多いと思います。<br />
                    無理に難しい曲から始めるのではなく、目的や生活リズムに合わせて進めます。
                </p>
            </div>

            {/* 5 Cards Grid */}
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
                {/* Card 1 */}
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-[10px] font-bold tracking-wider px-2.5 py-0.5 rounded-full mb-4">Worries 01</span>
                        <h3 class="text-lg font-bold text-[#544A40] mb-3 font-serif">まったくの初心者でも大丈夫？</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">楽譜の読み方、指番号、姿勢、リズムなど、基礎から確認します。大人になってから始める方もご相談いただけます。</p>
                    </div>
                </div>
                {/* Card 2 */}
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-[10px] font-bold tracking-wider px-2.5 py-0.5 rounded-full mb-4">Worries 02</span>
                        <h3 class="text-lg font-bold text-[#544A40] mb-3 font-serif">子どもの頃に習っていただけでも大丈夫？</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">以前弾いていた曲や現在の状態を確認しながら、無理なく再開できるところから始めます。</p>
                    </div>
                </div>
                {/* Card 3 */}
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-[10px] font-bold tracking-wider px-2.5 py-0.5 rounded-full mb-4">Worries 03</span>
                        <h3 class="text-lg font-bold text-[#544A40] mb-3 font-serif">好きな曲だけ弾きたい</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">クラシックだけでなく、弾いてみたい曲や目的に合わせて内容を相談できます。基礎も必要な範囲で取り入れます。</p>
                    </div>
                </div>
                {/* Card 4 */}
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-[10px] font-bold tracking-wider px-2.5 py-0.5 rounded-full mb-4">Worries 04</span>
                        <h3 class="text-lg font-bold text-[#544A40] mb-3 font-serif">練習時間があまり取れない</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">仕事や家事の予定に合わせて、短い練習でも続けやすい方法を一緒に考えます。</p>
                    </div>
                </div>
                {/* Card 5 */}
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow sm:col-span-2 lg:col-span-1 lg:col-start-2">
                    <div>
                        <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-[10px] font-bold tracking-wider px-2.5 py-0.5 rounded-full mb-4">Worries 05</span>
                        <h3 class="text-lg font-bold text-[#544A40] mb-3 font-serif">家に先生を呼ぶのが少し不安</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">ご自宅での受講が不安な場合は、近隣スタジオでのレッスンもご相談可能です。体験前に流れを確認できます。</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* 3. 目的別のレッスン内容 */}
    <section class="py-20 bg-[#FCFAF7] border-y border-[#E8E2D9]">
        <div class="max-w-5xl mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-2xl md:text-3xl font-serif text-[#544A40] mb-4">目的別のレッスン内容</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                    Lesson Styles
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                </div>
                <p class="text-sm text-[#6B5F54] leading-loose mt-6 max-w-2xl mx-auto">
                    大人のピアノレッスンでは、目的によって進め方が変わります。<br />
                    基礎から始めたい方、久しぶりに再開したい方、好きな曲を弾きたい方まで、ご希望に合わせて内容を相談できます。
                </p>
            </div>

            {/* 2x2 Grid */}
            <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
                {/* Card 1 */}
                <div class="bg-white p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-[10px] font-bold tracking-wider px-3 py-1 rounded-full mb-3 uppercase font-serif">Beginner</span>
                        <h3 class="text-xl font-bold text-[#544A40] mb-4 font-serif">初心者の方</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed mb-6">楽譜の読み方、指番号、リズム、姿勢など、基礎からゆっくり確認します。</p>
                    </div>
                    <div class="border-t border-[#E8E2D9] pt-4">
                        <p class="text-xs font-bold text-[#A88B58] mb-2 font-serif">主な内容：</p>
                        <ul class="space-y-2">
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54]">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>楽譜の読み方</span>
                            </li>
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54]">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>指番号</span>
                            </li>
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54]">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>リズム</span>
                            </li>
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54]">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>片手から両手への練習</span>
                            </li>
                        </ul>
                    </div>
                </div>

                {/* Card 2 */}
                <div class="bg-white p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-[10px] font-bold tracking-wider px-3 py-1 rounded-full mb-3 uppercase font-serif">Restart</span>
                        <h3 class="text-xl font-bold text-[#544A40] mb-4 font-serif">再開したい方</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed mb-6">以前の経験や現在の状態を確認しながら、無理なく弾けるところから再開します。</p>
                    </div>
                    <div class="border-t border-[#E8E2D9] pt-4">
                        <p class="text-xs font-bold text-[#A88B58] mb-2 font-serif">主な内容：</p>
                        <ul class="space-y-2">
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54]">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>基礎の見直し</span>
                            </li>
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54]">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>以前弾いていた曲</span>
                            </li>
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54]">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>指の動きの確認</span>
                            </li>
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54]">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>練習ペースの調整</span>
                            </li>
                        </ul>
                    </div>
