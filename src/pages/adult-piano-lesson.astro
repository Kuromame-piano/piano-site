---
import Layout from "../layouts/Layout.astro";
import FeeSystem from "../components/common/FeeSystem.astro";
import { areas } from "../data/areas";
import { Image } from "astro:assets";
import Breadcrumbs from "../components/common/Breadcrumbs.astro";
import InstructorProfile from "../components/common/InstructorProfile.astro";
import heroPiano from "../assets/images/hero-piano.webp";

const pageTitle = "大人の出張ピアノレッスン｜初心者・再開したい方も対応｜江東区・中央区周辺";
const pageDescription = "江東区・中央区周辺で大人向け出張ピアノレッスンを行っています。初心者、子どもの頃に習っていた方、好きな曲を弾きたい方も相談可能。月1回から、受講頻度や進め方をご相談しながら進めます。無料体験レッスン受付中です。";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Home",
                    "item": "https://playon-music.jp",
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "大人の出張ピアノレッスン",
                    "item": "https://playon-music.jp/adult-piano-lesson",
                },
            ],
        },
        {
            "@type": "Service",
            "name": "大人の出張ピアノレッスン",
            "provider": {
                "@type": "MusicSchool",
                "name": "髙橋遊月ピアノ教室",
                "url": "https://playon-music.jp",
                "image": "https://playon-music.jp/image.png",
            },
            "description": "江東区・中央区周辺で大人向け出張ピアノレッスンを行っています。初心者、子どもの頃に習っていた方、好きな曲を弾きたい方も相談可能。月1回から、受講頻度や進め方をご相談しながら進めます。",
            "url": "https://playon-music.jp/adult-piano-lesson"
        }
    ],
});

// Filter the specified areas from areas.ts
const targetAreaSlugs = [
    "kiyosumi-shirakawa", "monzen-nakacho", "kiba", "morishita", "sumiyoshi",
    "toyosu", "ariake", "shinonome", "tsukishima", "kachidoki", "harumi",
    "ningyocho", "suitengu-mae", "hamacho"
];

const adultAreas = areas.filter(a => targetAreaSlugs.includes(a.slug));
---

<Layout title={pageTitle} description={pageDescription}>
    <script type="application/ld+json" set:html={schema} slot="head" />

    <!-- Preload Critical Image -->
    <link slot="head" rel="preload" as="image" href={heroPiano.src} />

    <Breadcrumbs
        items={[
            { label: "ホーム", path: "/" },
            { label: "大人の出張ピアノレッスン", path: "/adult-piano-lesson" },
        ]}
    />

    {/* 1. Hero / First View */}
    <div class="relative h-[45vh] md:h-[55vh] flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 z-0">
            <Image
                src={heroPiano}
                alt="大人の出張ピアノレッスン"
                class="w-full h-full object-cover object-[50%_35%]"
                loading="eager"
            />
            <div class="absolute inset-0 bg-[#3A322B]/35"></div>
        </div>

        <div class="relative z-10 text-center text-white px-4 md:px-6 w-full max-w-4xl mx-auto">
            <h1 class="font-serif tracking-wide">
                <span class="block text-xs sm:text-sm font-bold tracking-[0.2em] mb-4 text-white/90 uppercase">
                    江東区・中央区周辺の大人の出張ピアノレッスン
                </span>

                <span class="flex items-center justify-center gap-4 md:gap-6 text-xs md:text-base mb-8 opacity-90">
                    <span class="h-[1px] w-8 md:w-16 bg-white/60"></span>
                    <span class="tracking-[0.2em] font-light uppercase">Adult Piano Lesson</span>
                    <span class="h-[1px] w-8 md:w-16 bg-white/60"></span>
                </span>

                <div class="flex items-baseline justify-center gap-0 mb-2 drop-shadow-lg">
                    <span class="text-3xl md:text-5xl lg:text-6xl font-medium tracking-tighter">
                        <span class="inline-block transform hover:scale-105 transition-transform duration-500 cursor-default">髙</span>
                        <span class="inline-block transform hover:scale-105 transition-transform duration-500 delay-75 cursor-default">橋</span>
                        <span class="inline-block transform hover:scale-105 transition-transform duration-500 delay-100 cursor-default">遊</span>
                        <span class="inline-block transform hover:scale-105 transition-transform duration-500 delay-150 cursor-default">月</span>
                    </span>
                    <span class="text-3xl md:text-5xl lg:text-6xl font-medium tracking-tighter opacity-90 drop-shadow-md">
                        ピアノ教室
                    </span>
                </div>
            </h1>

            <div class="mt-10">
                <span class="inline-block px-6 py-2 border border-white/30 rounded-full text-xs md:text-sm tracking-[0.15em] backdrop-blur-sm bg-white/10 text-white/90">
                    出張レッスン専門
                </span>
            </div>
        </div>
    </div>

    {/* Features Overview */}
    <section class="py-16 md:py-20 bg-[#FCFAF7] border-b border-[#E8E2D9]">
        <div class="max-w-5xl mx-auto px-6">
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center hover:shadow-md transition-all duration-300">
                    <div class="w-10 h-10 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-3 text-[#A88B58]">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                        </svg>
                    </div>
                    <h3 class="font-bold text-[#544A40] text-xs sm:text-sm mb-1 font-serif">初心者歓迎</h3>
                    <p class="text-[10px] text-[#6B5F54] leading-relaxed">楽譜の読み方や指番号など基礎から確認できます</p>
                </div>

                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center hover:shadow-md transition-all duration-300">
                    <div class="w-10 h-10 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-3 text-[#A88B58]">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
                        </svg>
                    </div>
                    <h3 class="font-bold text-[#544A40] text-xs sm:text-sm mb-1 font-serif">再開レッスン対応</h3>
                    <p class="text-[10px] text-[#6B5F54] leading-relaxed">現在の状態を見ながら無理なく再開できます</p>
                </div>

                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center hover:shadow-md transition-all duration-300">
                    <div class="w-10 h-10 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-3 text-[#A88B58]">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553z" />
                        </svg>
                    </div>
                    <h3 class="font-bold text-[#544A40] text-xs sm:text-sm mb-1 font-serif">好きな曲も相談可</h3>
                    <p class="text-[10px] text-[#6B5F54] leading-relaxed">弾きたい曲に合わせたレッスンも選べます</p>
                </div>

                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center hover:shadow-md transition-all duration-300">
                    <div class="w-10 h-10 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-3 text-[#A88B58]">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
                        </svg>
                    </div>
                    <h3 class="font-bold text-[#544A40] text-xs sm:text-sm mb-1 font-serif">月1回から相談可</h3>
                    <p class="text-[10px] text-[#6B5F54] leading-relaxed">生活リズムに合わせて無理なく続けられます</p>
                </div>
            </div>
        </div>
    </section>

    {/* 2. 大人のピアノでよくある不安 */}
    <section class="py-20 bg-white">
        <div class="max-w-5xl mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-2xl md:text-3xl font-serif text-[#544A40] mb-4">大人のピアノでよくある不安</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                    Common Worries
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                </div>
                <p class="text-sm text-[#6B5F54] leading-loose mt-6 max-w-2xl mx-auto">
                    大人になってからピアノを始めるときは、経験や年齢、練習時間のことが気になる方も多いと思います。<br />
                    無理に難しい曲から始めるのではなく、目的や生活リズムに合わせて進めます。
                </p>
            </div>

            {/* 6 Cards Grid */}
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 max-w-5xl mx-auto">
                {/* Card 1 */}
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-[10px] font-bold tracking-wider px-2.5 py-0.5 rounded-full mb-4">Worries 01</span>
                        <h3 class="text-lg font-bold text-[#544A40] mb-3 font-serif">まったくの初心者でも大丈夫？</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">楽譜の読み方、指番号、姿勢、リズムなど、基礎から確認します。大人になってから初めてピアノに触れる方も安心してお任せください。</p>
                    </div>
                </div>
                {/* Card 2 */}
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-[10px] font-bold tracking-wider px-2.5 py-0.5 rounded-full mb-4">Worries 02</span>
                        <h3 class="text-lg font-bold text-[#544A40] mb-3 font-serif">昔習っていただけだけど再開できる？</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">以前弾いていた曲や現在のブランクの長さに合わせ、指の感覚を優しく取り戻しながら、無理なく再開できるところから始めます。</p>
                    </div>
                </div>
                {/* Card 3 */}
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-[10px] font-bold tracking-wider px-2.5 py-0.5 rounded-full mb-4">Worries 03</span>
                        <h3 class="text-lg font-bold text-[#544A40] mb-3 font-serif">好きな曲・課題曲だけ弾きたい</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">クラシックだけでなく、ポップスや映画音楽、学校・他のスクールで指導された課題曲、苦手な部分だけを見てほしいというご要望も歓迎です。</p>
                    </div>
                </div>
                {/* Card 4 */}
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-[10px] font-bold tracking-wider px-2.5 py-0.5 rounded-full mb-4">Worries 04</span>
                        <h3 class="text-lg font-bold text-[#544A40] mb-3 font-serif">自分だけでは練習が進まない</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">仕事や家事で忙しく、家でなかなか練習時間が取れなくても大丈夫です。レッスン時間内で一緒に弾きながら、効率よく指を動かす練習を行います。</p>
                    </div>
                </div>
                {/* Card 5 */}
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-[10px] font-bold tracking-wider px-2.5 py-0.5 rounded-full mb-4">Worries 05</span>
                        <h3 class="text-lg font-bold text-[#544A40] mb-3 font-serif">表現・ペダル・音色までこだわりたい</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">ただ音符をなぞるだけでなく、ペダリングのタイミングや打鍵の強弱、美しい響きを出すための具体的なアドバイスも行います。</p>
                    </div>
                </div>
                {/* Card 6 */}
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-[10px] font-bold tracking-wider px-2.5 py-0.5 rounded-full mb-4">Worries 06</span>
                        <h3 class="text-lg font-bold text-[#544A40] mb-3 font-serif">自宅に先生を呼ぶのが難しい</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">ご自宅への出張レッスンに抵抗がある場合は、門前仲町や豊洲などの近隣レンタルスタジオを利用した対面レッスンもご相談いただけます。</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* 3. 目的別のレッスン内容 */}
    <section class="py-20 bg-[#FCFAF7] border-y border-[#E8E2D9]">
        <div class="max-w-5xl mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-2xl md:text-3xl font-serif text-[#544A40] mb-4">目的別のレッスン内容</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                    Lesson Styles
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                </div>
                <p class="text-sm text-[#6B5F54] leading-loose mt-6 max-w-2xl mx-auto">
                    大人のピアノレッスンでは、目的によって進め方が変わります。<br />
                    基礎から始めたい方、久しぶりに再開したい方、好きな曲を弾きたい方まで、ご希望に合わせて内容を相談できます。
                </p>
            </div>

            {/* 2x2 Grid */}
            <div class="grid md:grid-cols-2 gap-8 max-w-4xl mx-auto">
                {/* Card 1 */}
                <div class="bg-white p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-[10px] font-bold tracking-wider px-3 py-1 rounded-full mb-3 uppercase font-serif">Beginner</span>
                        <h3 class="text-xl font-bold text-[#544A40] mb-4 font-serif">大人の初心者の方へ</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed mb-6">楽譜の読み方や正しい手の形、基本的なリズムなど、一歩ずつ自分のペースで基礎を身につけます。憧れの曲を両手で弾けるようになるまで丁寧にサポートします。</p>
                    </div>
                    <div class="border-t border-[#E8E2D9] pt-4">
                        <p class="text-xs font-bold text-[#A88B58] mb-2 font-serif">このような方におすすめ：</p>
                        <ul class="space-y-2">
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54]">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>楽譜の読み方からじっくり学びたい</span>
                            </li>
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54]">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>ピアノに一度も触ったことがない</span>
                            </li>
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54]">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>年齢を気にせず新しい趣味を始めたい</span>
                            </li>
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54]">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>片手練習から自分のペースでゆっくり進めたい</span>
                            </li>
                        </ul>
                    </div>
                </div>

                {/* Card 2 */}
                <div class="bg-white p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-[10px] font-bold tracking-wider px-3 py-1 rounded-full mb-3 uppercase font-serif">Restart</span>
                        <h3 class="text-xl font-bold text-[#544A40] mb-4 font-serif">久しぶりにピアノを再開したい方へ</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed mb-6">子供の頃に習っていた方や、長年のブランクがある方向けです。以前の演奏レベルや指の感覚を思い出しながら、無理のないペースで好きな曲をまた奏でましょう。</p>
                    </div>
                    <div class="border-t border-[#E8E2D9] pt-4">
                        <p class="text-xs font-bold text-[#A88B58] mb-2 font-serif">このような方におすすめ：</p>
                        <ul class="space-y-2">
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54]">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>子供の頃のレッスン以来、ブランクがある</span>
                            </li>
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54]">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>ハノンやバイエルなどの基礎をもう一度見直したい</span>
                            </li>
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54]">
