---
import Layout from "../layouts/Layout.astro";
import FeeSystem from "../components/common/FeeSystem.astro";
import InstructorProfile from "../components/common/InstructorProfile.astro";
import { areas } from "../data/areas";

const pageTitle = "大人の出張ピアノレッスン｜初心者・再開したい方も対応｜江東区・中央区周辺";
const pageDescription = "江東区・中央区周辺で、大人向けの出張ピアノレッスンを行っています。初心者、久しぶりに再開したい方、好きな曲を弾きたい方も歓迎。月1回から相談可能、無料体験レッスン受付中です。";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Home",
                    "item": "https://playon-music.jp",
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "大人の出張ピアノレッスン",
                    "item": "https://playon-music.jp/adult-piano-lesson",
                },
            ],
        },
        {
            "@type": "Service",
            "name": "大人の出張ピアノレッスン",
            "provider": {
                "@type": "MusicSchool",
                "name": "髙橋遊月ピアノ教室",
                "url": "https://playon-music.jp",
                "image": "https://playon-music.jp/senzai.png",
            },
            "description": "江東区・中央区周辺で、大人向けの出張ピアノレッスンを行っています。初心者、久しぶりに再開したい方、好きな曲を弾きたい方も歓迎。月1回から相談可能、無料体験レッスン受付中です。",
            "url": "https://playon-music.jp/adult-piano-lesson"
        }
    ],
});

const instructorIntro = `髙橋 遊月
東京音楽大学 卒業

江東区・清澄白河周辺を中心に、ご自宅へのピアノ出張レッスンを行っています。
大人の方の初心者レッスンや再開レッスンにも対応し、弾きたい曲や生活リズムに合わせて、無理なく続けられるレッスンを一緒に考えます。`;

// Filter the specified areas from areas.ts
const targetAreaSlugs = [
    "kiyosumi-shirakawa", "monzen-nakacho", "kiba", "morishita", "sumiyoshi",
    "toyosu", "ariake", "shinonome", "tsukishima", "kachidoki", "harumi",
    "ningyocho", "suitengu-mae", "hamacho"
];

const adultAreas = areas.filter(a => targetAreaSlugs.includes(a.slug));
---

<Layout title={pageTitle} description={pageDescription}>
    <script type="application/ld+json" set:html={schema} slot="head" />

    {/* Hero / First View */}
    <section class="relative bg-gradient-to-b from-[#F7F3EE] to-[#FCFAF7] py-20 md:py-28 overflow-hidden">
        <div class="max-w-6xl mx-auto px-6 relative z-10">
            <div class="grid lg:grid-cols-[55%_45%] gap-12 items-center">
                <div>
                    <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-xs font-bold tracking-[0.2em] px-4 py-1.5 rounded-full mb-6 font-serif uppercase">
                        Adult Piano Lesson
                    </span>
                    <h1 class="font-serif text-[#544A40] mb-6">
                        <span class="block text-xs md:text-sm font-bold tracking-[0.15em] text-[#A88B58] mb-3 uppercase font-sans">
                            大人の出張ピアノレッスン
                        </span>
                        <span class="block text-3xl md:text-4xl lg:text-5xl leading-snug">
                            大人になってからでも、<br class="hidden md:block" />ピアノは始められます
                        </span>
                    </h1>
                    <p class="text-sm md:text-base text-[#6B5F54] leading-loose mb-10">
                        髙橋遊月ピアノ教室では、江東区・中央区周辺を中心に、大人の方のための出張ピアノレッスンを行っています。<br />
                        初めてピアノに触れる方、子どもの頃に習っていて再開したい方、好きな曲を自分のペースで弾きたい方まで、目的に合わせてレッスン内容を調整します。
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4">
                        <a href="/contact?from=adult-piano-lesson" class="inline-block bg-[#A88B58] text-white text-center font-bold px-8 py-4 rounded-full shadow-lg hover:bg-[#8B7347] transition-all duration-300 transform hover:-translate-y-1 text-sm tracking-wider whitespace-nowrap">
                            無料体験レッスンを申し込む
                        </a>
                        <a href="/contact?from=adult-piano-lesson&message=大人のレッスンについての相談です。" class="inline-block bg-[#544A40] text-white text-center font-bold px-8 py-4 rounded-full shadow-lg hover:bg-[#3D352E] transition-all duration-300 transform hover:-translate-y-1 text-sm tracking-wider whitespace-nowrap">
                            大人のレッスンについて相談する
                        </a>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">初心者歓迎</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">楽譜の読み方や指の使い方から丁寧に進めます</p>
                    </div>

                    <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">再開レッスン対応</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">昔習っていた感覚をブランクに合わせて取り戻します</p>
                    </div>

                    <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">好きな曲も相談可</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">クラシックやポップス等、弾きたい曲に取り組めます</p>
                    </div>

                    <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">月1回から相談可</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">無理のない頻度で忙しい日常とも両立できます</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* Section 1: Worries */}
    <section class="py-24 bg-white">
        <div class="max-w-5xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-2xl md:text-3xl font-serif text-[#544A40] mb-4">大人のピアノでよくある不安</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                    Common Worries
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                </div>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow duration-300">
                    <div>
                        <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center font-bold font-serif text-sm mb-4">1</div>
                        <h3 class="text-base font-bold text-[#544A40] mb-3 font-serif">楽譜が読めない</h3>
                        <p class="text-sm text-[#6B5F54] leading-loose">楽譜の読み方から、基礎の基礎から確認できます。</p>
                    </div>
                </div>

                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow duration-300">
                    <div>
                        <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center font-bold font-serif text-sm mb-4">2</div>
                        <h3 class="text-base font-bold text-[#544A40] mb-3 font-serif">指が動くか不安</h3>
                        <p class="text-sm text-[#6B5F54] leading-loose">無理な速さで進めず、指の使い方や姿勢から丁寧に確認します。</p>
                    </div>
                </div>

                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow duration-300">
                    <div>
                        <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center font-bold font-serif text-sm mb-4">3</div>
                        <h3 class="text-base font-bold text-[#544A40] mb-3 font-serif">練習時間が取れない</h3>
                        <p class="text-sm text-[#6B5F54] leading-loose">忙しい時期は、練習量や進度を調整しながら続けられます。</p>
                    </div>
                </div>

                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow duration-300">
                    <div>
                        <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center font-bold font-serif text-sm mb-4">4</div>
                        <h3 class="text-base font-bold text-[#544A40] mb-3 font-serif">子どもの頃にやめてしまった</h3>
                        <p class="text-sm text-[#6B5F54] leading-loose">ブランクがあっても、以前の経験を確認しながら再開できます。</p>
                    </div>
                </div>

                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow duration-300">
                    <div>
                        <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center font-bold font-serif text-sm mb-4">5</div>
                        <h3 class="text-base font-bold text-[#544A40] mb-3 font-serif">人前で弾くのは恥ずかしい</h3>
                        <p class="text-sm text-[#6B5F54] leading-loose">マンツーマンレッスンなので、周りを気にせず自分のペースで受けられます。</p>
                    </div>
                </div>

                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow duration-300">
                    <div>
                        <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center font-bold font-serif text-sm mb-4">6</div>
                        <h3 class="text-base font-bold text-[#544A40] mb-3 font-serif">好きな曲だけ弾きたい</h3>
                        <p class="text-sm text-[#6B5F54] leading-loose">基礎を確認しながら、弾いてみたい曲にも取り組めます。</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* Section 2: Why Visit Lesson Fits Adults */}
    <section class="py-24 bg-[#FCFAF7] border-y border-[#E8E2D9]">
        <div class="max-w-5xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-2xl md:text-3xl font-serif text-[#544A40] mb-4">大人の方に出張レッスンが向いている理由</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                    Why Visit Lesson fits Adults
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                </div>
            </div>

            <div class="grid lg:grid-cols-[40%_60%] gap-12 items-center">
                <div class="space-y-6">
                    <p class="text-base text-[#6B5F54] leading-loose">
                        仕事や家事で忙しい大人の方にとって、教室へ通う時間を確保することが負担になる場合があります。
                    </p>
                    <p class="text-base text-[#6B5F54] leading-loose">
                        出張レッスンなら、ご自宅で受けられるため、移動時間を減らし、生活リズムの中にピアノを取り入れやすくなります。
                    </p>
                </div>

                <div class="grid sm:grid-cols-2 gap-6">
                    <div class="bg-white p-6 rounded-xl border border-[#E8E2D9] shadow-sm flex items-start gap-4">
                        <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center flex-shrink-0 mt-0.5">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                        </div>
                        <div>
                            <h4 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">移動時間を減らせる</h4>
                            <p class="text-xs text-[#6B5F54] leading-relaxed">仕事や家事の合間に効率よく受講可能。</p>
                        </div>
                    </div>

                    <div class="bg-white p-6 rounded-xl border border-[#E8E2D9] shadow-sm flex items-start gap-4">
                        <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center flex-shrink-0 mt-0.5">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                        </div>
                        <div>
                            <h4 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">仕事後や休日に相談しやすい</h4>
                            <p class="text-xs text-[#6B5F54] leading-relaxed">ご自身のスケジュールに合わせて枠を調整。</p>
                        </div>
                    </div>

                    <div class="bg-white p-6 rounded-xl border border-[#E8E2D9] shadow-sm flex items-start gap-4">
                        <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center flex-shrink-0 mt-0.5">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                        </div>
                        <div>
                            <h4 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">自宅の楽器でそのまま練習できる</h4>
                            <p class="text-xs text-[#6B5F54] leading-relaxed">レッスンで弾いた感触でそのまま日々練習可能。</p>
                        </div>
                    </div>

                    <div class="bg-white p-6 rounded-xl border border-[#E8E2D9] shadow-sm flex items-start gap-4">
                        <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center flex-shrink-0 mt-0.5">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                        </div>
                        <div>
                            <h4 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">月1回〜4回まで相談できる</h4>
                            <p class="text-xs text-[#6B5F54] leading-relaxed">生活スタイルに合わせて受講回数を選択可能。</p>
                        </div>
                    </div>

                    <div class="bg-white p-6 rounded-xl border border-[#E8E2D9] shadow-sm flex items-start gap-4">
                        <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center flex-shrink-0 mt-0.5">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                        </div>
                        <div>
                            <h4 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">周りを気にせずマンツーマン</h4>
                            <p class="text-xs text-[#6B5F54] leading-relaxed">他の生徒の音や視線を気にせず集中できます。</p>
                        </div>
                    </div>

                    <div class="bg-white p-6 rounded-xl border border-[#E8E2D9] shadow-sm flex items-start gap-4">
                        <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center flex-shrink-0 mt-0.5">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
                        </div>
                        <div>
                            <h4 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">忙しい時期は進度を調整できる</h4>
                            <p class="text-xs text-[#6B5F54] leading-relaxed">仕事の繁忙期などがあっても柔軟に変更可能です。</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* Section 3: Objectives */}
    <section class="py-24 bg-white">
        <div class="max-w-5xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-2xl md:text-3xl font-serif text-[#544A40] mb-4">このような目的に対応できます</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                    Objectives & Goals
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                </div>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-2 font-serif">Beginner</span>
                        <h3 class="text-lg font-bold text-[#544A40] mb-3 font-serif border-b border-[#E8E2D9] pb-2">1. 初めてピアノを習いたい</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">楽譜の読み方、指番号、姿勢など、基礎から始めます。</p>
                    </div>
                </div>

