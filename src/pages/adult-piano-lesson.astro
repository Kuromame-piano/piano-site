---
import Layout from "../layouts/Layout.astro";
import FeeSystem from "../components/common/FeeSystem.astro";
import InstructorProfile from "../components/common/InstructorProfile.astro";
import { areas } from "../data/areas";

const pageTitle = "大人の出張ピアノレッスン｜初心者・再開したい方も対応｜江東区・中央区周辺";
const pageDescription = "江東区・中央区周辺で大人向け出張ピアノレッスンを行っています。初心者、子どもの頃に習っていた方、好きな曲を弾きたい方も相談可能。月1回から、生活リズムに合わせて無理なく始められます。無料体験レッスン受付中です。";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Home",
                    "item": "https://playon-music.jp",
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "大人の出張ピアノレッスン",
                    "item": "https://playon-music.jp/adult-piano-lesson",
                },
            ],
        },
        {
            "@type": "Service",
            "name": "大人の出張ピアノレッスン",
            "provider": {
                "@type": "MusicSchool",
                "name": "髙橋遊月ピアノ教室",
                "url": "https://playon-music.jp",
                "image": "https://playon-music.jp/image.png",
            },
            "description": "江東区・中央区周辺で大人向け出張ピアノレッスンを行っています。初心者、子どもの頃に習っていた方、好きな曲を弾きたい方も相談可能。月1回から、生活リズムに合わせて無理なく始められます。",
            "url": "https://playon-music.jp/adult-piano-lesson"
        }
    ],
});

const instructorIntro = `髙橋 遊月
東京音楽大学 卒業

大人の初心者の方や、子どもの頃に習っていて再開したい方にも対応しています。
弾いてみたい曲や生活リズムをお聞きしながら、無理なく続けられる内容を一緒に考えます。
楽譜の読み方や指の使い方など、基礎から確認したい方もご相談ください。

ピアノを通して、生活の中に音楽を楽しむ時間を少しずつ増やしていけるようなレッスンを大切にしています。`;

// Filter the specified areas from areas.ts
const targetAreaSlugs = [
    "kiyosumi-shirakawa", "monzen-nakacho", "kiba", "morishita", "sumiyoshi",
    "toyosu", "ariake", "shinonome", "tsukishima", "kachidoki", "harumi",
    "ningyocho", "suitengu-mae", "hamacho"
];

const adultAreas = areas.filter(a => targetAreaSlugs.includes(a.slug));
---

<Layout title={pageTitle} description={pageDescription}>
    <script type="application/ld+json" set:html={schema} slot="head" />

    {/* Hero / First View */}
    <section class="relative bg-gradient-to-b from-[#F7F3EE] to-[#FCFAF7] py-20 md:py-28 overflow-hidden">
        <div class="max-w-6xl mx-auto px-6 relative z-10">
            <div class="grid lg:grid-cols-[55%_45%] gap-12 items-center">
                <div>
                    <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-xs font-bold tracking-[0.2em] px-4 py-1.5 rounded-full mb-6 font-serif uppercase">
                        Adult Piano Lesson
                    </span>
                    <h1 class="font-serif text-[#544A40] mb-6">
                        <span class="block text-2xl sm:text-3xl md:text-4xl lg:text-5xl leading-snug">
                            <span class="inline-block">江東区・中央区周辺の</span><br class="hidden md:block" /><span class="inline-block">大人向け</span><span class="inline-block">出張ピアノレッスン</span>
                        </span>
                    </h1>
                    <p class="text-sm md:text-base text-[#6B5F54] leading-loose mb-10">
                        初心者の方、子どもの頃に習っていて再開したい方、好きな曲を自分のペースで弾きたい方へ。<br />
                        ご自宅や近隣スタジオで、生活リズムに合わせて無理なく始められる大人のピアノレッスンです。
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 mb-6">
                        <a href="https://lin.ee/QL31tIZ" target="_blank" rel="noopener noreferrer" id="hero-cta-trial" class="inline-flex items-center justify-center bg-[#06C755] hover:bg-[#05b04b] text-white text-center font-bold px-8 py-4 rounded-full shadow-lg transition-all duration-300 transform hover:-translate-y-1 text-sm tracking-wider whitespace-nowrap line_click_firstview gap-2">
                            <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current" xmlns="http://www.w3.org/2000/svg">
                                <path d="M22 10.02c0-4.428-4.486-8.02-10-8.02S2 5.592 2 10.02c0 3.966 3.23 7.284 7.6 7.907.296.064.697.195.797.447.091.229.06.588.029.842-.116.892-.375 2.564-.427 2.9-.06.398.146.365.309.244.152-.113 2.454-1.619 3.456-2.319.721.2 1.488.31 2.236.31 5.514 0 10-3.593 10-8.021z"/>
                            </svg>
                            LINEで大人のレッスンを相談する
                        </a>
                        <a href="#fees" id="hero-cta-consult" class="inline-flex items-center justify-center bg-[#A88B58] hover:bg-[#8B7347] text-white text-center font-bold px-8 py-4 rounded-full shadow-lg transition-all duration-300 transform hover:-translate-y-1 text-sm tracking-wider whitespace-nowrap">
                            料金を見る
                        </a>
                    </div>
                    <p class="text-xs text-[#6B5F54] tracking-wider leading-relaxed">
                        ※自宅まで来てもらえるか、電子ピアノでも大丈夫か、曜日や時間だけ確認したい段階でも、公式LINEから気軽にご相談いただけます。
                    </p>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">初心者歓迎</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">楽譜の読み方、指番号、姿勢など基礎から確認できます</p>
                    </div>

                    <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">再開レッスン対応</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">ブランクがある方も、現在の状態を見ながら再開できます</p>
                    </div>

                    <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">好きな曲も相談可</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">クラシック、ポップス、映画音楽など弾きたい曲をご相談ください</p>
                    </div>

                    <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">月1回から相談可</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">空き枠やご希望に合わせて、月1回〜ご相談いただけます</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* Section 1: Common Worries */}
    <section class="py-20 bg-white">
        <div class="max-w-5xl mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-2xl md:text-3xl font-serif text-[#544A40] mb-4">大人のピアノでよくある不安</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                    Common Worries
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                </div>
                <p class="text-sm text-[#6B5F54] leading-loose mt-6 max-w-2xl mx-auto">
                    大人になってからピアノを始めるときは、技術面だけでなく「今から始めても大丈夫か」「練習時間を取れるか」といった不安もあると思います。<br />
                    現在の経験や生活リズムに合わせて、無理のない内容から始められます。
                </p>
            </div>

            {/* Row 1: 3 cards */}
            <div class="grid sm:grid-cols-3 gap-6 mb-6">
                <div class="bg-[#FCFAF7] p-6 rounded-2xl border border-[#E8E2D9] shadow-sm hover:shadow-md transition-shadow duration-300">
                    <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center font-bold font-serif text-sm mb-3">1</div>
                    <h3 class="text-base font-bold text-[#544A40] mb-2 font-serif">楽譜が読めない</h3>
                    <p class="text-sm text-[#6B5F54] leading-relaxed">音の名前、リズム、指番号など、基礎から確認できます。</p>
                </div>
                <div class="bg-[#FCFAF7] p-6 rounded-2xl border border-[#E8E2D9] shadow-sm hover:shadow-md transition-shadow duration-300">
                    <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center font-bold font-serif text-sm mb-3">2</div>
                    <h3 class="text-base font-bold text-[#544A40] mb-2 font-serif">指が動くか不安</h3>
                    <p class="text-sm text-[#6B5F54] leading-relaxed">無理な速さで進めず、手の使い方や姿勢から見直します。</p>
                </div>
                <div class="bg-[#FCFAF7] p-6 rounded-2xl border border-[#E8E2D9] shadow-sm hover:shadow-md transition-shadow duration-300">
                    <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center font-bold font-serif text-sm mb-3">3</div>
                    <h3 class="text-base font-bold text-[#544A40] mb-2 font-serif">練習時間が取れない</h3>
                    <p class="text-sm text-[#6B5F54] leading-relaxed">忙しい時期は、宿題の量や進め方を相談できます。</p>
                </div>
            </div>
            {/* Row 2: 3 cards */}
            <div class="grid sm:grid-cols-3 gap-6">
                <div class="bg-[#FCFAF7] p-6 rounded-2xl border border-[#E8E2D9] shadow-sm hover:shadow-md transition-shadow duration-300">
                    <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center font-bold font-serif text-sm mb-3">4</div>
                    <h3 class="text-base font-bold text-[#544A40] mb-2 font-serif">子どもの頃にやめてしまった</h3>
                    <p class="text-sm text-[#6B5F54] leading-relaxed">以前の経験を確認しながら、無理なく再開できるところから始めます。</p>
                </div>
                <div class="bg-[#FCFAF7] p-6 rounded-2xl border border-[#E8E2D9] shadow-sm hover:shadow-md transition-shadow duration-300">
                    <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center font-bold font-serif text-sm mb-3">5</div>
                    <h3 class="text-base font-bold text-[#544A40] mb-2 font-serif">人前で弾くのは恥ずかしい</h3>
                    <p class="text-sm text-[#6B5F54] leading-relaxed">マンツーマンなので、周りを気にせず自分のペースで受けられます。</p>
                </div>
                <div class="bg-[#FCFAF7] p-6 rounded-2xl border border-[#E8E2D9] shadow-sm hover:shadow-md transition-shadow duration-300">
                    <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center font-bold font-serif text-sm mb-3">6</div>
                    <h3 class="text-base font-bold text-[#544A40] mb-2 font-serif">家に先生を呼ぶのが少し不安</h3>
                    <p class="text-sm text-[#6B5F54] leading-relaxed">体験前に、レッスン場所や当日の流れを確認できます。スタジオ利用もご相談ください。</p>
                </div>
            </div>
        </div>
    </section>

    {/* Section 2: Lessons by Purpose (merged) */}
    <section class="py-20 bg-[#FCFAF7] border-y border-[#E8E2D9]">
        <div class="max-w-5xl mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-2xl md:text-3xl font-serif text-[#544A40] mb-4">目的別のレッスン内容</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                    Lessons by Purpose
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                </div>
                <p class="text-sm md:text-base text-[#6B5F54] leading-loose mt-6 max-w-2xl mx-auto">
                    経験や目的、練習できる時間に合わせて内容を調整します。<br class="hidden md:block" />
                    基礎から始めたい方も、好きな曲を弾きたい方も、今の状態に合うところから進めます。
                </p>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm hover:shadow-md transition-shadow">
                    <div>
                        <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-2 font-serif">Beginner</span>
                        <h3 class="text-base font-bold text-[#544A40] mb-3 font-serif border-b border-[#E8E2D9] pb-2">初めてピアノを習いたい</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">楽譜の読み方、指番号、姿勢、片手練習など、基礎から始めます。</p>
                    </div>
                </div>

                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm hover:shadow-md transition-shadow">
                    <div>
                        <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-2 font-serif">Restart</span>
                        <h3 class="text-base font-bold text-[#544A40] mb-3 font-serif border-b border-[#E8E2D9] pb-2">子どもの頃のピアノを再開したい</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">ブランクを確認しながら、以前の経験を活かして無理なく再開します。</p>
                    </div>
                </div>

                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm hover:shadow-md transition-shadow">
                    <div>
                        <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-2 font-serif">Favorite Songs</span>
                        <h3 class="text-base font-bold text-[#544A40] mb-3 font-serif border-b border-[#E8E2D9] pb-2">好きな曲を弾きたい</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">クラシック、ポップス、映画音楽など、弾いてみたい曲をご相談いただけます。</p>
                    </div>
                </div>

                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm hover:shadow-md transition-shadow">
                    <div>
                        <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-2 font-serif">Hobby</span>
                        <h3 class="text-base font-bold text-[#544A40] mb-3 font-serif border-b border-[#E8E2D9] pb-2">趣味として長く続けたい</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">上達だけを急がず、生活の中で続けやすいペースを一緒に考えます。</p>
                    </div>
                </div>

                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm hover:shadow-md transition-shadow">
                    <div>
                        <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-2 font-serif">Practical</span>
                        <h3 class="text-base font-bold text-[#544A40] mb-3 font-serif border-b border-[#E8E2D9] pb-2">保育や学校の伴奏に取り組みたい</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">必要に応じて、伴奏曲や実用的な曲の練習もご相談いただけます。</p>
                    </div>
                </div>

                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm hover:shadow-md transition-shadow">
                    <div>
                        <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-2 font-serif">Senior</span>
                        <h3 class="text-base font-bold text-[#544A40] mb-3 font-serif border-b border-[#E8E2D9] pb-2">シニアから始めたい</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">体力や生活リズムに合わせて、無理のない内容から始めます。</p>
                    </div>
                </div>
            </div>

            {/* 小CTA */}
            <div class="mt-12 text-center bg-white p-6 md:p-8 rounded-2xl border border-[#E8E2D9] max-w-2xl mx-auto shadow-sm">
                <p class="text-sm text-[#6B5F54] leading-relaxed mb-6">
                    大人の方は、月1回からの受講や、好きな曲を中心にしたレッスンもご相談いただけます。久しぶりで不安な方も、公式LINEから気軽にご相談ください。
                </p>
                <a
                    href="https://lin.ee/QL31tIZ"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center bg-[#06C755] hover:bg-[#05b04b] text-white px-6 py-3.5 rounded-full font-bold shadow-sm transition-all duration-300 text-xs tracking-wider line_click_purpose gap-2"
                >
                    <svg viewBox="0 0 24 24" class="w-4 h-4 fill-current" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22 10.02c0-4.428-4.486-8.02-10-8.02S2 5.592 2 10.02c0 3.966 3.23 7.284 7.6 7.907.296.064.697.195.797.447.091.229.06.588.029.842-.116.892-.375 2.564-.427 2.9-.06.398.146.365.309.244.152-.113 2.454-1.619 3.456-2.319.721.2 1.488.31 2.236.31 5.514 0 10-3.593 10-8.021z"/>
                    </svg>
                    初心者・再開レッスンをLINEで相談する
                </a>
            </div>
        </div>
    </section>

    {/* Section 3: Why Visit Lesson Fits Adults */}
    <section class="py-20 bg-white">
