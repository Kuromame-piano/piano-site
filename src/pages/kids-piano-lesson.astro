---
import Layout from "../layouts/Layout.astro";
import FeeSystem from "../components/common/FeeSystem.astro";
import { areas } from "../data/areas";
import { Image } from "astro:assets";

const pageTitle = "子どもの出張ピアノレッスン｜江東区・中央区の自宅で習えるピアノ教室";
const pageDescription = "江東区・中央区周辺で子ども向け出張ピアノレッスンを行っています。未就学児・小学生・中学生まで、送迎不要でご自宅のピアノや電子ピアノで受講可能。無料体験レッスン受付中です。";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Home",
                    "item": "https://playon-music.jp",
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "子どもの出張ピアノレッスン",
                    "item": "https://playon-music.jp/kids-piano-lesson",
                },
            ],
        },
        {
            "@type": "Service",
            "name": "子どもの出張ピアノレッスン",
            "provider": {
                "@type": "MusicSchool",
                "name": "髙橋遊月ピアノ教室",
                "url": "https://playon-music.jp",
                "image": "https://playon-music.jp/image.png",
            },
            "description": "江東区・中央区周辺で、未就学児・小学生・中学生向けの出張ピアノレッスンを行っています。送迎不要でご自宅で習えます。",
            "url": "https://playon-music.jp/kids-piano-lesson"
        }
    ],
});

// Filter the specified areas from areas.ts
const targetAreaSlugs = [
    "kiyosumi-shirakawa", "monzen-nakacho", "kiba", "morishita", "sumiyoshi",
    "toyosu", "ariake", "shinonome", "tsukishima", "kachidoki", "harumi",
    "ningyocho", "suitengu-mae", "hamacho"
];

const kidsAreas = areas.filter(a => targetAreaSlugs.includes(a.slug));
---

<Layout title={pageTitle} description={pageDescription}>
    <script type="application/ld+json" set:html={schema} slot="head" />

    {/* 1. Hero / First View */}
    <section class="relative bg-gradient-to-b from-[#F7F3EE] to-[#FCFAF7] py-16 md:py-24 overflow-hidden">
        <div class="max-w-6xl mx-auto px-6 relative z-10">
            <div class="grid lg:grid-cols-[55%_45%] gap-12 items-center">
                <div>
                    <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-xs font-bold tracking-[0.2em] px-4 py-1.5 rounded-full mb-6 font-serif uppercase">
                        Kids Piano Lesson
                    </span>
                    <h1 class="font-serif text-[#544A40] mb-4">
                        <span class="block text-xs sm:text-sm font-bold tracking-widest text-[#A88B58] mb-2 uppercase">江東区・中央区周辺の</span>
                        <span class="block text-2xl sm:text-3xl md:text-4xl lg:text-5xl leading-snug font-bold">
                            子ども向け出張<br />ピアノレッスン
                        </span>
                    </h1>
                    <p class="text-sm sm:text-base md:text-lg text-[#A88B58] font-bold mb-6 font-serif">
                        送迎なしで、ご自宅のピアノ・電子ピアノから始められます
                    </p>
                    <p class="text-sm md:text-base text-[#6B5F54] leading-loose mb-8">
                        未就学のお子様から小学生・中学生まで、年齢や集中力に合わせて無理なく進める子ども向けのピアノレッスンです。<br />
                        ご自宅で受けられるため、送迎の負担を減らしながら、普段の楽器でレッスンできます。
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 mb-6">
                        <a href="https://lin.ee/QL31tIZ" target="_blank" rel="noopener noreferrer" id="hero-cta-trial" class="inline-flex items-center justify-center bg-[#06C755] hover:bg-[#05b04b] text-white text-center font-bold px-6 py-4 rounded-full shadow-lg transition-all duration-300 transform hover:-translate-y-1 text-xs sm:text-sm tracking-wider gap-2 line_click_firstview">
                            <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current" xmlns="http://www.w3.org/2000/svg">
                                <path d="M22 10.02c0-4.428-4.486-8.02-10-8.02S2 5.592 2 10.02c0 3.966 3.23 7.284 7.6 7.907.296.064.697.195.797.447.091.229.06.588.029.842-.116.892-.375 2.564-.427 2.9-.06.398.146.365.309.244.152-.113 2.454-1.619 3.456-2.319.721.2 1.488.31 2.236.31 5.514 0 10-3.593 10-8.021z"/>
                            </svg>
                            公式LINEで子どもの体験レッスンを相談する
                        </a>
                        <a href="#fees" id="hero-cta-consult" class="inline-flex items-center justify-center bg-white hover:bg-[#F7F3EE] text-[#544A40] border border-[#E8E2D9] text-center font-bold px-6 py-4 rounded-full shadow-sm transition-all duration-300 transform hover:-translate-y-1 text-xs sm:text-sm tracking-wider">
                            料金を見る
                        </a>
                    </div>
                    <p class="text-xs text-[#6B5F54] tracking-wider leading-relaxed">
                        自宅まで来てもらえるか、電子ピアノでも大丈夫か、曜日や時間だけ確認したい段階でも、公式LINEからご相談いただけます。
                    </p>
                </div>

                <div class="grid grid-cols-2 gap-3 sm:gap-4">
                    <div class="bg-white p-4 sm:p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-10 h-10 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-3 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-xs sm:text-sm mb-1 font-serif">未就学児から相談可</h3>
                        <p class="text-[10px] text-[#6B5F54] leading-relaxed">年齢や集中力に合わせ無理なく進めます</p>
                    </div>

                    <div class="bg-white p-4 sm:p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-10 h-10 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-3 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-xs sm:text-sm mb-1 font-serif">送迎不要</h3>
                        <p class="text-[10px] text-[#6B5F54] leading-relaxed">ご自宅でのレッスンで送迎負担をゼロに</p>
                    </div>

                    <div class="bg-white p-4 sm:p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-10 h-10 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-3 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-xs sm:text-sm mb-1 font-serif">電子ピアノ相談可</h3>
                        <p class="text-[10px] text-[#6B5F54] leading-relaxed">ご自宅の電子ピアノで始められます</p>
                    </div>

                    <div class="bg-white p-4 sm:p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-10 h-10 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-3 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-xs sm:text-sm mb-1 font-serif">無料体験あり</h3>
                        <p class="text-[10px] text-[#6B5F54] leading-relaxed">まずは無料体験レッスンをお試しください</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* 2. 子どものピアノでよくあるお悩み */}
    <section class="py-16 md:py-24 bg-white">
        <div class="max-w-5xl mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-2xl md:text-3xl font-serif text-[#544A40] mb-4">子どものピアノでよくあるお悩み</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                    Common Worries
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                </div>
                <p class="text-sm text-[#6B5F54] leading-loose mt-6 max-w-2xl mx-auto">
                    初めての習い事や自宅レッスンでは、始める前に不安なことも多いと思います。<br />
                    年齢や集中力、ご家庭の生活リズムに合わせて、無理なく続けられる形を一緒に考えます。
                </p>
            </div>

            {/* Row 1: 3 cards */}
            <div class="grid md:grid-cols-3 gap-6 mb-6">
                <div class="bg-[#FCFAF7] p-6 rounded-2xl border border-[#E8E2D9] shadow-sm hover:shadow-md transition-shadow duration-300">
                    <div class="text-xs text-[#A88B58] font-bold font-serif mb-2">01</div>
                    <h3 class="text-base font-bold text-[#544A40] mb-2 font-serif">教室まで送迎する時間がない</h3>
                    <p class="text-xs sm:text-sm text-[#6B5F54] leading-relaxed">ご自宅でレッスンを受けられるため、学校・学童・塾の前後にも組み込みやすくなります。</p>
                </div>
                <div class="bg-[#FCFAF7] p-6 rounded-2xl border border-[#E8E2D9] shadow-sm hover:shadow-md transition-shadow duration-300">
                    <div class="text-xs text-[#A88B58] font-bold font-serif mb-2">02</div>
                    <h3 class="text-base font-bold text-[#544A40] mb-2 font-serif">まだ集中力が続くか不安</h3>
                    <p class="text-xs sm:text-sm text-[#6B5F54] leading-relaxed">年齢や性格に合わせて、短い内容から無理なく始めます。最初から長時間集中できなくても大丈夫です。</p>
                </div>
                <div class="bg-[#FCFAF7] p-6 rounded-2xl border border-[#E8E2D9] shadow-sm hover:shadow-md transition-shadow duration-300">
                    <div class="text-xs text-[#A88B58] font-bold font-serif mb-2">03</div>
                    <h3 class="text-base font-bold text-[#544A40] mb-2 font-serif">電子ピアノでも始められるか知りたい</h3>
                    <p class="text-xs sm:text-sm text-[#6B5F54] leading-relaxed">88鍵盤で、タッチによる強弱がつく電子ピアノを推奨しています。体験時に楽器環境を確認できます。</p>
                </div>
            </div>
            {/* Row 2: 2 cards centered */}
            <div class="grid md:grid-cols-2 gap-6 max-w-2xl mx-auto">
                <div class="bg-[#FCFAF7] p-6 rounded-2xl border border-[#E8E2D9] shadow-sm hover:shadow-md transition-shadow duration-300">
                    <div class="text-xs text-[#A88B58] font-bold font-serif mb-2">04</div>
                    <h3 class="text-base font-bold text-[#544A40] mb-2 font-serif">家で練習を続けられるか不安</h3>
                    <p class="text-xs sm:text-sm text-[#6B5F54] leading-relaxed">毎日長時間ではなく、「今週はここだけ」のように、短くても続けやすい練習方法を一緒に考えます。</p>
                </div>
                <div class="bg-[#FCFAF7] p-6 rounded-2xl border border-[#E8E2D9] shadow-sm hover:shadow-md transition-shadow duration-300">
                    <div class="text-xs text-[#A88B58] font-bold font-serif mb-2">05</div>
                    <h3 class="text-base font-bold text-[#544A40] mb-2 font-serif">初めての習い事で不安</h3>
                    <p class="text-xs sm:text-sm text-[#6B5F54] leading-relaxed">楽譜の読み方、指番号、リズムなど、基礎からゆっくり確認します。保護者の方がピアノ経験者でなくても大丈夫です。</p>
                </div>
            </div>


        </div>
    </section>

    {/* 3. 年齢別のレッスンイメージ */}
    <section class="py-16 md:py-24 bg-[#FCFAF7] border-y border-[#E8E2D9]">
        <div class="max-w-5xl mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-2xl md:text-3xl font-serif text-[#544A40] mb-4">年齢別のレッスンイメージ</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                    Lessons by Age
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                </div>
                <p class="text-sm md:text-base text-[#6B5F54] leading-loose mt-6 max-w-2xl mx-auto">
                    お子様の年齢、集中力、ピアノ経験に合わせて、内容や時間を調整します。<br />
                    最初から完璧に弾くことを目指すのではなく、音やリズムに慣れること、少しずつ弾ける範囲を増やすことを大切にしています。
                </p>
            </div>

            <div class="grid md:grid-cols-3 gap-6 items-stretch">
                {/* Preschool */}
                <div class="bg-white p-7 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase font-serif">Preschool</span>
                            <span class="bg-[#A88B58]/10 text-[#A88B58] text-[10px] sm:text-xs font-bold px-2.5 py-0.5 rounded-full">30分 × 月3回</span>
                        </div>
                        <h3 class="text-lg font-bold text-[#544A40] mb-3 font-serif border-b border-[#E8E2D9] pb-2">未就学のお子様</h3>
                        <p class="text-xs sm:text-sm text-[#6B5F54] leading-relaxed mb-6">
                            音やリズムに親しむところから始めます。短い時間でも集中しやすい内容にし、必要に応じて保護者の方にも進め方を共有します。
                        </p>
                    </div>
                    <div>
                        <p class="text-xs font-bold text-[#A88B58] mb-2 font-serif">主な内容：</p>
                        <ul class="space-y-2">
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54] leading-relaxed">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>音やリズムに慣れる</span>
                            </li>
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54] leading-relaxed">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>鍵盤に触れる</span>
                            </li>
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54] leading-relaxed">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>指番号を覚える</span>
                            </li>
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54] leading-relaxed">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>短い曲やリズム遊び</span>
                            </li>
                        </ul>
                    </div>
                </div>

                {/* Elementary */}
                <div class="bg-white p-7 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase font-serif">Elementary</span>
                            <span class="bg-[#A88B58]/10 text-[#A88B58] text-[10px] sm:text-xs font-bold px-2.5 py-0.5 rounded-full">30〜45分 × 月3回</span>
                        </div>
                        <h3 class="text-lg font-bold text-[#544A40] mb-3 font-serif border-b border-[#E8E2D9] pb-2">小学生</h3>
                        <p class="text-xs sm:text-sm text-[#6B5F54] leading-relaxed mb-6">
                            楽譜の読み方、指の形、姿勢、リズムを確認しながら、好きな曲にも少しずつ挑戦できます。
                        </p>
                    </div>
                    <div>
                        <p class="text-xs font-bold text-[#A88B58] mb-2 font-serif">主な内容：</p>
                        <ul class="space-y-2">
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54] leading-relaxed">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>楽譜の読み方</span>
                            </li>
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54] leading-relaxed">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>指の形や姿勢</span>
                            </li>
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54] leading-relaxed">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>片手から両手への練習</span>
                            </li>
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54] leading-relaxed">
                                <span class="text-[#A88B58] mt-1 flex-shrink-0"><svg class="w-3 h-3" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>好きな曲への挑戦</span>
                            </li>
                            <li class="flex items-start gap-2 text-xs sm:text-sm text-[#6B5F54] leading-relaxed">
