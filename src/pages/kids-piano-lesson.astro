---
import Layout from "../layouts/Layout.astro";
import FeeSystem from "../components/common/FeeSystem.astro";
import InstructorProfile from "../components/common/InstructorProfile.astro";
import { areas } from "../data/areas";

const pageTitle = "子どもの出張ピアノレッスン｜江東区・中央区の自宅で習えるピアノ教室";
const pageDescription = "江東区・中央区周辺で、未就学児・小学生・中学生向けの出張ピアノレッスンを行っています。送迎不要で、ご自宅のピアノや電子ピアノで受講可能。無料体験レッスン受付中です。";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Home",
                    "item": "https://playon-music.jp",
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "子どもの出張ピアノレッスン",
                    "item": "https://playon-music.jp/kids-piano-lesson",
                },
            ],
        },
        {
            "@type": "Service",
            "name": "子どもの出張ピアノレッスン",
            "provider": {
                "@type": "MusicSchool",
                "name": "髙橋遊月ピアノ教室",
                "url": "https://playon-music.jp",
                "image": "https://playon-music.jp/senzai.png",
            },
            "description": "江東区・中央区周辺で、未就学児・小学生・中学生向けの出張ピアノレッスンを行っています。送迎不要でご自宅で習えます。",
            "url": "https://playon-music.jp/kids-piano-lesson"
        }
    ],
});

const instructorIntro = `髙橋 遊月
東京音楽大学 卒業

お子様の初めてのピアノから、大人の方の再開レッスンまで、目的に合わせた個人レッスンを行っています。
お子様の年齢や性格、ご家庭の生活リズムに合わせて、無理なく続けられるレッスンを一緒に考えます。`;

// Filter the specified areas from areas.ts
const targetAreaSlugs = [
    "kiyosumi-shirakawa", "monzen-nakacho", "kiba", "morishita", "sumiyoshi",
    "toyosu", "ariake", "shinonome", "tsukishima", "kachidoki", "harumi",
    "ningyocho", "suitengu-mae", "hamacho"
];

const kidsAreas = areas.filter(a => targetAreaSlugs.includes(a.slug));
---

<Layout title={pageTitle} description={pageDescription}>
    <script type="application/ld+json" set:html={schema} slot="head" />

    {/* Hero / First View */}
    <section class="relative bg-gradient-to-b from-[#F7F3EE] to-[#FCFAF7] py-20 md:py-28 overflow-hidden">
        <div class="max-w-6xl mx-auto px-6 relative z-10">
            <div class="grid lg:grid-cols-[55%_45%] gap-12 items-center">
                <div>
                    <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-xs font-bold tracking-[0.2em] px-4 py-1.5 rounded-full mb-6 font-serif uppercase">
                        Kids Piano Lesson
                    </span>
                    <h1 class="font-serif text-[#544A40] mb-6">
                        <span class="block text-xs md:text-sm font-bold tracking-[0.15em] text-[#A88B58] mb-3 uppercase font-sans">
                            子どもの出張ピアノレッスン
                        </span>
                        <span class="block text-3xl md:text-4xl lg:text-5xl leading-snug">
                            送迎の負担を減らして、<br class="hidden md:block" />ご自宅で始める子どものピアノ
                        </span>
                    </h1>
                    <p class="text-sm md:text-base text-[#6B5F54] leading-loose mb-10">
                        髙橋遊月ピアノ教室では、江東区・中央区周辺を中心に、未就学のお子様から小学生・中学生まで、一人ひとりのペースに合わせた出張ピアノレッスンを行っています。<br />
                        ご自宅で受けられるため、学校・学童・塾の前後にも組み込みやすく、保護者の方の送迎負担も減らせます。
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4">
                        <a href="/contact?from=kids-piano-lesson" class="inline-block bg-[#A88B58] text-white text-center font-bold px-8 py-4 rounded-full shadow-lg hover:bg-[#8B7347] transition-all duration-300 transform hover:-translate-y-1 text-sm tracking-wider whitespace-nowrap">
                            無料体験レッスンを申し込む
                        </a>
                        <a href="/contact?from=kids-piano-lesson&message=子どものレッスンについての相談です。" class="inline-block bg-[#544A40] text-white text-center font-bold px-8 py-4 rounded-full shadow-lg hover:bg-[#3D352E] transition-all duration-300 transform hover:-translate-y-1 text-sm tracking-wider whitespace-nowrap">
                            子どものレッスンについて相談する
                        </a>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4">
                    <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">未就学児から相談可</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">幼児期の早い段階から、成長に合わせて優しく導入</p>
                    </div>

                    <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">送迎不要</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">往復の移動時間をなくし、忙しい夕方の時間を有効活用</p>
                    </div>

                    <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 6.553v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 1 1-.99-3.467l2.31-.66a2.25 2.25 0 0 0 1.632-2.163zm0 0V2.25L9 5.25v10.303m0 0v3.75a2.25 2.25 0 0 1-1.632 2.163l-1.32.377a1.803 1.803 0 0 1-.99-3.467l2.31-.66A2.25 2.25 0 0 0 9 15.553z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">電子ピアノ相談可</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">アップライトがなくとも、お持ちの電子ピアノで可能</p>
                    </div>

                    <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">無料体験あり</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">まずは実際の出張スタイルでお試しいただけます</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* Section 1: Common Worries */}
    <section class="py-24 bg-white">
        <div class="max-w-5xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-2xl md:text-3xl font-serif text-[#544A40] mb-4">子どものピアノでよくあるお悩み</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                    Common Worries
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                </div>
            </div>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow duration-300">
                    <div>
                        <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center font-bold font-serif text-sm mb-4">1</div>
                        <h3 class="text-base font-bold text-[#544A40] mb-3 font-serif">教室まで送迎する時間がない</h3>
                        <p class="text-sm text-[#6B5F54] leading-loose">学校・学童・塾のあとに教室へ通うのが負担になりやすいご家庭に、出張レッスンは向いています。</p>
                    </div>
                </div>

                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow duration-300">
                    <div>
                        <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center font-bold font-serif text-sm mb-4">2</div>
                        <h3 class="text-base font-bold text-[#544A40] mb-3 font-serif">まだ集中力が続くか不安</h3>
                        <p class="text-sm text-[#6B5F54] leading-loose">年齢や性格に合わせて、短い時間でも無理なく取り組めるように進めます。</p>
                    </div>
                </div>

                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow duration-300">
                    <div>
                        <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center font-bold font-serif text-sm mb-4">3</div>
                        <h3 class="text-base font-bold text-[#544A40] mb-3 font-serif">電子ピアノでも始められるか知りたい</h3>
                        <p class="text-sm text-[#6B5F54] leading-loose">電子ピアノでもレッスン可能です。体験時に楽器環境を確認できます。</p>
                    </div>
                </div>

                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow duration-300 md:col-span-1">
                    <div>
                        <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center font-bold font-serif text-sm mb-4">4</div>
                        <h3 class="text-base font-bold text-[#544A40] mb-3 font-serif">練習を続けられるか不安</h3>
                        <p class="text-sm text-[#6B5F54] leading-loose">毎日長時間練習することよりも、短くても続けやすい練習方法を一緒に考えます。</p>
                    </div>
                </div>

                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow duration-300 md:col-span-2 lg:col-span-2">
                    <div>
                        <div class="w-8 h-8 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center font-bold font-serif text-sm mb-4">5</div>
                        <h3 class="text-base font-bold text-[#544A40] mb-3 font-serif">初めての習い事で不安</h3>
                        <p class="text-sm text-[#6B5F54] leading-loose">楽譜の読み方、指の使い方、リズムなど、基礎からゆっくり確認します。</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* Section 2: Lessons by Age */}
    <section class="py-24 bg-[#FCFAF7] border-y border-[#E8E2D9]">
        <div class="max-w-5xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-2xl md:text-3xl font-serif text-[#544A40] mb-2">年齢・経験に合わせたレッスン</h2>
                <p class="text-xs md:text-sm text-[#A88B58] font-serif mb-4 tracking-[0.15em]">一人ひとりの成長に合わせて進めます</p>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                    Lessons by Age
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                </div>
            </div>

            <p class="text-sm md:text-base text-[#6B5F54] leading-loose text-center max-w-3xl mx-auto mb-16">
                お子様の年齢、集中力、性格、経験に合わせて、レッスン内容を調整します。<br class="hidden md:block" />
                最初から完璧に弾くことを目指すのではなく、音を楽しむこと、楽譜に慣れること、少しずつ弾ける感覚を積み重ねることを大切にします。
            </p>

            <div class="grid md:grid-cols-3 gap-8">
                {/* Preschool */}
                <div class="bg-white p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-2 font-serif">Preschool</span>
                        <h3 class="text-xl font-bold text-[#544A40] mb-6 font-serif border-b border-[#E8E2D9] pb-3">未就学のお子様</h3>
                        <ul class="space-y-4">
                            <li class="flex items-start gap-2.5 text-sm text-[#6B5F54] leading-relaxed">
                                <span class="text-[#A88B58] mt-1.5 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>音やリズムに親しむ</span>
                            </li>
                            <li class="flex items-start gap-2.5 text-sm text-[#6B5F54] leading-relaxed">
                                <span class="text-[#A88B58] mt-1.5 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>短い時間で集中しやすい内容にする</span>
                            </li>
                            <li class="flex items-start gap-2.5 text-sm text-[#6B5F54] leading-relaxed">
                                <span class="text-[#A88B58] mt-1.5 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>楽しく鍵盤に触れる</span>
                            </li>
                            <li class="flex items-start gap-2.5 text-sm text-[#6B5F54] leading-relaxed">
                                <span class="text-[#A88B58] mt-1.5 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>必要に応じて保護者の方にも進め方を共有する</span>
                            </li>
                        </ul>
                    </div>
                </div>

                {/* Elementary */}
                <div class="bg-white p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-2 font-serif">Elementary</span>
                        <h3 class="text-xl font-bold text-[#544A40] mb-6 font-serif border-b border-[#E8E2D9] pb-3">小学生</h3>
                        <ul class="space-y-4">
                            <li class="flex items-start gap-2.5 text-sm text-[#6B5F54] leading-relaxed">
                                <span class="text-[#A88B58] mt-1.5 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>楽譜の読み方</span>
                            </li>
                            <li class="flex items-start gap-2.5 text-sm text-[#6B5F54] leading-relaxed">
                                <span class="text-[#A88B58] mt-1.5 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>指の形や姿勢</span>
                            </li>
                            <li class="flex items-start gap-2.5 text-sm text-[#6B5F54] leading-relaxed">
                                <span class="text-[#A88B58] mt-1.5 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>リズム</span>
                            </li>
                            <li class="flex items-start gap-2.5 text-sm text-[#6B5F54] leading-relaxed">
                                <span class="text-[#A88B58] mt-1.5 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>片手から両手への練習</span>
                            </li>
                            <li class="flex items-start gap-2.5 text-sm text-[#6B5F54] leading-relaxed">
                                <span class="text-[#A88B58] mt-1.5 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>学校や生活リズムに合わせた練習方法</span>
                            </li>
                        </ul>
                    </div>
                </div>

                {/* Junior High */}
                <div class="bg-white p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between hover:shadow-md transition-shadow">
                    <div>
                        <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-2 font-serif">Junior High</span>
                        <h3 class="text-xl font-bold text-[#544A40] mb-6 font-serif border-b border-[#E8E2D9] pb-3">中学生</h3>
                        <ul class="space-y-4">
                            <li class="flex items-start gap-2.5 text-sm text-[#6B5F54] leading-relaxed">
                                <span class="text-[#A88B58] mt-1.5 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>部活や塾と両立しながら続ける</span>
                            </li>
                            <li class="flex items-start gap-2.5 text-sm text-[#6B5F54] leading-relaxed">
                                <span class="text-[#A88B58] mt-1.5 flex-shrink-0"><svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="3" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg></span>
                                <span>好きな曲への挑戦</span>
