                            {/* Content */}
                            <div class="flex-1 pt-0.5">
                                <div class="flex flex-col md:flex-row md:items-baseline gap-2 md:gap-4 mb-3">
                                    <span class="text-xs font-serif text-[#A88B58] tracking-widest">
