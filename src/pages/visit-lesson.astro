---
import Layout from "../layouts/Layout.astro";
import FeeSystem from "../components/common/FeeSystem.astro";
import InstructorProfile from "../components/common/InstructorProfile.astro";

const pageTitle = "東京・江東区周辺の出張ピアノレッスン｜自宅で習える髙橋遊月ピアノ教室";
const pageDescription = "江東区・中央区周辺で、ご自宅やスタジオへの出張ピアノレッスンを行っています。送迎不要で、子どもから大人まで対応。入会金無料・出張費込み・無料体験レッスン受付中です。";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Home",
                    "item": "https://playon-music.jp",
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "出張ピアノレッスン",
                    "item": "https://playon-music.jp/visit-lesson",
                },
            ],
        },
    ],
});

const instructorIntro = `髙橋 遊月
東京音楽大学 卒業

江東区・清澄白河周辺を中心に、ご自宅へのピアノ出張レッスンを行っています。
お子様の初めてのピアノから、大人の方の再開レッスンまで、目的やペースに合わせて個人レッスンを行います。`;

const areas = [
    { name: "清澄白河", slug: "kiyosumi-shirakawa" },
    { name: "門前仲町", slug: "monzen-nakacho" },
    { name: "木場", slug: "kiba" },
    { name: "森下", slug: "morishita" },
    { name: "住吉", slug: "sumiyoshi" },
    { name: "豊洲", slug: "toyosu" },
    { name: "有明", slug: "ariake" },
    { name: "東雲", slug: "shinonome" },
    { name: "月島", slug: "tsukishima" },
    { name: "勝どき", slug: "kachidoki" },
    { name: "晴海", slug: "harumi" },
    { name: "人形町", slug: "ningyocho" },
    { name: "水天宮前", slug: "suitengu-mae" },
    { name: "日本橋浜町", slug: "hamacho" },
];
---

<Layout title={pageTitle} description={pageDescription}>
    <script type="application/ld+json" set:html={schema} slot="head" />

    {/* Section 0: Hero / First View */}
    <section class="relative bg-gradient-to-b from-[#F7F3EE] to-[#FCFAF7] py-20 md:py-28 overflow-hidden">
        <div class="max-w-6xl mx-auto px-6 relative z-10">
            <div class="grid lg:grid-cols-[55%_45%] gap-12 items-center">
                <div>
                    <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-xs font-bold tracking-[0.2em] px-4 py-1.5 rounded-full mb-6 font-serif uppercase">
                        Visiting Piano Lesson
                    </span>
                    <h1 class="font-serif text-[#544A40] mb-6">
                        <span class="block text-xs md:text-sm font-bold tracking-[0.15em] text-[#A88B58] mb-3 uppercase font-sans">
                            東京・江東区周辺の出張ピアノレッスン
                        </span>
                        <span class="block text-3xl md:text-4xl lg:text-5xl leading-snug">
                            ご自宅で、無理なく<br class="hidden md:block" />続けられるピアノレッスン
                        </span>
                    </h1>
                    <p class="text-sm md:text-base text-[#6B5F54] leading-loose mb-10">
                        髙橋遊月ピアノ教室では、江東区・中央区周辺を中心に、ご自宅または近隣スタジオへ講師が伺う出張ピアノレッスンを行っています。<br class="hidden md:block" />
                        教室への送迎が難しいお子様の習い事としても、仕事後や休日に始めたい大人の方のレッスンとしてもご相談いただけます。
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4">
                        <a href="/contact?from=visit-lesson" class="inline-block bg-[#A88B58] text-white text-center font-bold px-8 py-4 rounded-full shadow-lg hover:bg-[#8B7347] transition-all duration-300 transform hover:-translate-y-1 text-sm tracking-wider whitespace-nowrap">
                            無料体験レッスンを申し込む
                        </a>
                        <a href="/contact?from=visit-lesson&message=自宅まで来てもらえるかどうかの相談です。" class="inline-block bg-[#544A40] text-white text-center font-bold px-8 py-4 rounded-full shadow-lg hover:bg-[#3D352E] transition-all duration-300 transform hover:-translate-y-1 text-sm tracking-wider whitespace-nowrap">
                            自宅まで来てもらえるか相談する
                        </a>
                    </div>
                </div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.129-1.125V11.25M3 14.25h16.5M3 14.25v-3.375C3 9.47 4.47 8 6.28 8h11.44c1.81 0 3.28 1.47 3.28 3.28v3.375" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-base mb-1 font-serif">送迎不要</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">移動時間を節約し、いつもの我が家で効率的レッスン</p>
                    </div>
                    
                    <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5h16.5M5.25 7.5h13.5m-12 3h10.5M8.25 13.5h7.5M10.5 16.5h3" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-base mb-1 font-serif">出張費込み</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">対応エリア内の交通費・出張費はすべて料金に含む</p>
                    </div>
                    
                    <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-base mb-1 font-serif">子ども・大人対応</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">幼児の初めてのピアノから、大人の再開レッスンまで</p>
                    </div>
                    
                    <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-12 h-12 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-6 h-6">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-base mb-1 font-serif">無料体験あり</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">まずはご自宅環境や相性を体験レッスンで確認</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* Section 1: What is Visiting Piano Lesson */}
    <section class="py-24 bg-white">
        <div class="max-w-4xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-2xl md:text-3xl font-serif text-[#544A40] mb-4">出張ピアノレッスンとは</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                    What is Visiting Lesson
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                </div>
            </div>
            
            <div class="bg-[#FCFAF7] p-8 md:p-12 rounded-[2rem] border border-[#E8E2D9] shadow-sm">
                <h3 class="text-lg md:text-xl font-serif text-[#544A40] mb-6 leading-relaxed text-center">
                    講師が生徒様のご自宅へ伺い、<br class="md:hidden" />普段練習しているピアノや電子ピアノでレッスンを行うスタイルです。
                </h3>
                <p class="text-sm md:text-base text-[#6B5F54] leading-loose text-center max-w-2xl mx-auto mb-10">
                    教室へ通う必要がないため、送迎や移動の負担を減らしながら、いつもの環境で落ち着いてレッスンを受けられます。
                </p>
                
                <div class="grid md:grid-cols-2 gap-8 mt-4">
                    <div class="flex items-start gap-4">
                        <div class="w-6 h-6 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center mt-1 flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                            </svg>
                        </div>
                        <div>
                            <h4 class="font-bold font-serif text-[#544A40] text-sm md:text-base mb-1">自宅で受けられる</h4>
                            <p class="text-xs text-[#6B5F54] leading-relaxed">いつもの安心できる部屋で、リラックスして講師とマンツーマンでピアノに向き合えます。</p>
                        </div>
                    </div>
                    
                    <div class="flex items-start gap-4">
                        <div class="w-6 h-6 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center mt-1 flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                            </svg>
                        </div>
                        <div>
                            <h4 class="font-bold font-serif text-[#544A40] text-sm md:text-base mb-1">普段の楽器で練習できる</h4>
                            <p class="text-xs text-[#6B5F54] leading-relaxed">レッスン時に、普段ご自宅で使っているピアノの感触や響きをそのまま確認・指導できます。</p>
                        </div>
                    </div>
                    
                    <div class="flex items-start gap-4">
                        <div class="w-6 h-6 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center mt-1 flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                            </svg>
                        </div>
                        <div>
                            <h4 class="font-bold font-serif text-[#544A40] text-sm md:text-base mb-1">移動時間がかからない</h4>
                            <p class="text-xs text-[#6B5F54] leading-relaxed">開始直前まで他の予定に取り組め、終わったらすぐに自宅での練習や宿題に移行できます。</p>
                        </div>
                    </div>
                    
                    <div class="flex items-start gap-4">
                        <div class="w-6 h-6 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center mt-1 flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                            </svg>
                        </div>
                        <div>
                            <h4 class="font-bold font-serif text-[#544A40] text-sm md:text-base mb-1">子どもは保護者の送迎負担が減る</h4>
                            <p class="text-xs text-[#6B5F54] leading-relaxed">送り迎えの予定を組む必要がなく、忙しい保護者様のスケジュールに余裕が生まれます。</p>
                        </div>
                    </div>
                    
                    <div class="flex items-start gap-4">
                        <div class="w-6 h-6 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center mt-1 flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                            </svg>
                        </div>
                        <div>
                            <h4 class="font-bold font-serif text-[#544A40] text-sm md:text-base mb-1">大人は仕事後や休日に組み込みやすい</h4>
                            <p class="text-xs text-[#6B5F54] leading-relaxed">週末や夜の枠を活用し、帰宅後のリラックスタイムを有効に使ってレッスンを受けられます。</p>
                        </div>
                    </div>
                    
                    <div class="flex items-start gap-4">
                        <div class="w-6 h-6 rounded-full bg-[#A88B58]/10 text-[#A88B58] flex items-center justify-center mt-1 flex-shrink-0">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" />
                            </svg>
                        </div>
                        <div>
                            <h4 class="font-bold font-serif text-[#544A40] text-sm md:text-base mb-1">家にピアノがない場合はスタジオも相談可能</h4>
                            <p class="text-xs text-[#6B5F54] leading-relaxed">ご自宅に鍵盤がない場合でも、最寄りのピアノスタジオへ講師が伺ってレッスンできます。</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* Section 2: Recommended For */}
    <section class="py-24 bg-[#FCFAF7] border-y border-[#E8E2D9]">
        <div class="max-w-5xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-2xl md:text-3xl font-serif text-[#544A40] mb-4">このような方におすすめです</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                    Recommended For
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                </div>
            </div>
            
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                <div class="bg-white p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between transform hover:scale-[1.01] transition-transform duration-300">
                    <div>
                        <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-3 font-serif">01. Busy Parents</span>
                        <h3 class="text-lg font-bold text-[#544A40] mb-3 font-serif">お子様の送迎が難しいご家庭</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">学校・学童・塾のあとに教室へ移動する負担を減らしたい方に向いています。</p>
                    </div>
                </div>
                
                <div class="bg-white p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between transform hover:scale-[1.01] transition-transform duration-300">
                    <div>
                        <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-3 font-serif">02. Consistent Practice</span>
                        <h3 class="text-lg font-bold text-[#544A40] mb-3 font-serif">自宅のピアノで習いたい方</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">普段練習している楽器でレッスンを受けることで、日々の練習にもつなげやすくなります。</p>
                    </div>
                </div>
                
                <div class="bg-white p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between transform hover:scale-[1.01] transition-transform duration-300">
                    <div>
                        <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-3 font-serif">03. Simple Start</span>
                        <h3 class="text-lg font-bold text-[#544A40] mb-3 font-serif">電子ピアノで始めたい方</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">88鍵盤でタッチによる強弱がつく電子ピアノであれば、レッスン可能です。体験時に楽器環境の確認もできます。</p>
                    </div>
                </div>
                
                <div class="bg-white p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between md:col-span-2 lg:col-span-1 transform hover:scale-[1.01] transition-transform duration-300">
                    <div>
                        <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-3 font-serif">04. Lifelong Learning</span>
                        <h3 class="text-lg font-bold text-[#544A40] mb-3 font-serif">大人になってから始めたい方</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">初心者の方、昔習っていて再開したい方、好きな曲を弾きたい方にも対応しています。</p>
                    </div>
                </div>
                
                <div class="bg-white p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between md:col-span-2 lg:col-span-2 transform hover:scale-[1.01] transition-transform duration-300">
                    <div>
                        <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-3 font-serif">05. Lifestyle Fit</span>
                        <h3 class="text-lg font-bold text-[#544A40] mb-3 font-serif">忙しい中でも無理なく続けたい方</h3>
                        <p class="text-sm text-[#6B5F54] leading-relaxed">月1回〜4回まで、生活リズムに合わせて頻度を相談できます。無理のない進度プランをご提案します。</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* Section 3: Difference from regular classes */}
    <section class="py-24 bg-white">
        <div class="max-w-4xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-2xl md:text-3xl font-serif text-[#544A40] mb-4">教室に通うレッスンとの違い</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                    Comparison
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                </div>
            </div>
            
            <div class="overflow-x-auto shadow-sm rounded-2xl border border-[#E8E2D9]">
                <table class="w-full min-w-[600px] border-collapse text-sm text-[#544A40]">
                    <thead>
                        <tr class="border-b border-[#E8E2D9] bg-[#FCFAF7]">
                            <th class="py-4 px-6 text-left font-serif font-bold w-1/4">項目</th>
                            <th class="py-4 px-6 text-left font-serif font-bold w-3/8 text-[#6B5F54]">通うレッスン</th>
