                                    <h3 class="text-lg md:text-xl font-medium text-[#544A40]">
                                        {step.title}
                                    </h3>
                                </div>
                                <p class="text-[15px] text-[#544A40]/80 leading-7 text-justify">
                                    {step.description}
                                </p>
                            </div>
                        </div>
                    ))}
                </div>
            </div>
        </div>
