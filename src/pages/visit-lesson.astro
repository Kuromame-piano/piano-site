---
import Layout from "../layouts/Layout.astro";
import FeeSystem from "../components/common/FeeSystem.astro";
import InstructorProfile from "../components/common/InstructorProfile.astro";

const pageTitle = "出張ピアノレッスン｜江東区・中央区周辺の自宅で習えるピアノ教室";
const pageDescription = "江東区・中央区周辺で出張ピアノレッスンを行っています。ご自宅のピアノや電子ピアノで受講でき、対応エリア内は出張費・交通費込み。子どもから大人の初心者・再開レッスンまで、無料体験レッスンでご相談いただけます。";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Home",
                    "item": "https://playon-music.jp",
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "出張ピアノレッスン",
                    "item": "https://playon-music.jp/visit-lesson",
                },
            ],
        },
    ],
});

const instructorIntro = `江東区・中央区周辺を中心に、ご自宅や近隣スタジオでの出張ピアノレッスンを行っています。

お子様の初めてのピアノから、大人の初心者・再開レッスンまで、年齢や目的に合わせて進めます。

ご自宅の楽器環境や生活リズムも確認しながら、無理なく続けられる形を一緒に考えます。`;

const areas = [
    { name: "清澄白河", slug: "kiyosumi-shirakawa" },
    { name: "門前仲町", slug: "monzen-nakacho" },
    { name: "木場", slug: "kiba" },
    { name: "森下", slug: "morishita" },
    { name: "住吉", slug: "sumiyoshi" },
    { name: "豊洲", slug: "toyosu" },
    { name: "有明", slug: "ariake" },
    { name: "東雲", slug: "shinonome" },
    { name: "月島", slug: "tsukishima" },
    { name: "勝どき", slug: "kachidoki" },
    { name: "晴海", slug: "harumi" },
    { name: "人形町", slug: "ningyocho" },
    { name: "水天宮前", slug: "suitengu-mae" },
    { name: "日本橋浜町", slug: "hamacho" },
];
---

<Layout title={pageTitle} description={pageDescription}>
    <script type="application/ld+json" set:html={schema} slot="head" />

    {/* Section 0: Hero / First View */}
    <section class="relative bg-gradient-to-b from-[#F7F3EE] to-[#FCFAF7] py-16 md:py-24 overflow-hidden">
        <div class="max-w-6xl mx-auto px-6 relative z-10">
            <div class="grid lg:grid-cols-[55%_45%] gap-12 items-center">
                <div>
                    <span class="inline-block bg-[#A88B58]/10 text-[#A88B58] text-xs font-bold tracking-[0.2em] px-4 py-1.5 rounded-full mb-6 font-serif uppercase">
                        Visiting Piano Lesson
                    </span>
                    <h1 class="font-serif text-[#544A40] mb-6">
                        <span class="block text-xs md:text-sm font-bold tracking-[0.15em] text-[#A88B58] mb-3 uppercase font-sans">
                            江東区・中央区周辺の出張ピアノレッスン
                        </span>
                        <span class="block text-2xl md:text-4xl lg:text-5xl leading-snug">
                            ご自宅で、無理なく<br class="hidden md:block" />続けられるピアノレッスン
                        </span>
                    </h1>
                    <p class="text-sm md:text-base text-[#6B5F54] leading-loose mb-10">
                        ご自宅のピアノや電子ピアノで受けられる出張ピアノレッスンです。<br />
                        送迎の負担を減らしたいご家庭や、教室に通う時間を取りにくい大人の方もご相談いただけます。<br class="hidden md:block" />
                        対応エリア内は、出張費・交通費込みの料金です。ご自宅での受講が難しい場合は、近隣スタジオでのレッスンもご相談いただけます。
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 mb-4">
                        <a
                            href="https://lin.ee/QL31tIZ"
                            target="_blank"
                            rel="noopener noreferrer"
                            class="inline-flex items-center justify-center bg-[#06C755] hover:bg-[#05b04b] text-white text-center font-bold px-6 sm:px-8 py-3.5 sm:py-4 rounded-full shadow-lg transition-all duration-300 transform hover:-translate-y-0.5 text-xs sm:text-sm tracking-wider gap-2 line_click_visit_cta"
                        >
                            <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current" xmlns="http://www.w3.org/2000/svg">
                                <path d="M22 10.02c0-4.428-4.486-8.02-10-8.02S2 5.592 2 10.02c0 3.966 3.23 7.284 7.6 7.907.296.064.697.195.797.447.091.229.06.588.029.842-.116.892-.375 2.564-.427 2.9-.06.398.146.365.309.244.152-.113 2.454-1.619 3.456-2.319.721.2 1.488.31 2.236.31 5.514 0 10-3.593 10-8.021z"/>
                            </svg>
                            公式LINEで無料体験を相談する
                        </a>
                        <a
                            href="#fees"
                            class="inline-flex items-center justify-center bg-[#A88B58] hover:bg-[#8B7347] text-white text-center font-bold px-6 sm:px-8 py-3.5 sm:py-4 rounded-full shadow-lg transition-all duration-300 transform hover:-translate-y-0.5 text-xs sm:text-sm tracking-wider"
                        >
                            料金を見る
                        </a>
                    </div>
                    <p class="text-xs text-[#6B5F54] tracking-wider leading-relaxed">
                        ※自宅まで来てもらえるか、電子ピアノでも大丈夫か、曜日や時間だけ確認したい段階でも、公式LINEから気軽にご相談いただけます。
                    </p>
                </div>
                
                <div class="grid grid-cols-2 gap-4">
                    <div class="bg-white p-5 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-10 h-10 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-3 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.129-1.125V11.25M3 14.25h16.5M3 14.25v-3.375C3 9.47 4.47 8 6.28 8h11.44c1.81 0 3.28 1.47 3.28 3.28v3.375" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">送迎不要</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">教室への移動なしで、ご自宅で受けられます。</p>
                    </div>
                    
                    <div class="bg-white p-5 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-10 h-10 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-3 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5h16.5M5.25 7.5h13.5m-12 3h10.5M8.25 13.5h7.5M10.5 16.5h3" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">出張費込み</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">対応エリア内は、出張費・交通費込みの料金です。</p>
                    </div>
                    
                    <div class="bg-white p-5 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-10 h-10 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-3 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">子ども・大人対応</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">未就学のお子様から、大人の初心者・再開レッスンまでご相談いただけます。</p>
                    </div>
                    
                    <div class="bg-white p-5 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center transform hover:scale-[1.02] transition-transform duration-300">
                        <div class="w-10 h-10 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-3 text-[#A88B58]">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
                            </svg>
                        </div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-1 font-serif">無料体験あり</h3>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">ご自宅でのレッスンが合うか、体験時に確認できます。</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* Section 1: What is Visiting Piano Lesson */}
    <section class="py-20 bg-white">
        <div class="max-w-4xl mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-xl md:text-2xl font-serif text-[#544A40] mb-3">出張ピアノレッスンとは</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-6 bg-[#A88B58]/30"></div>
                    What is Visiting Lesson
                    <div class="h-[1px] w-6 bg-[#A88B58]/30"></div>
                </div>
            </div>
            
            <div class="bg-[#FCFAF7] p-6 md:p-10 rounded-[2rem] border border-[#E8E2D9] shadow-sm">
                <p class="text-sm md:text-base text-[#6B5F54] leading-loose text-center max-w-2xl mx-auto mb-8">
                    講師がご自宅または近隣スタジオへ伺い、ピアノや電子ピアノでレッスンを行うスタイルです。<br />
                    教室へ通う必要がないため、送迎や移動の負担を減らしながら、普段の練習環境に合わせてレッスンできます。
                </p>
                
                <div class="grid md:grid-cols-2 gap-6 mt-4">
                    <div class="bg-white p-5 rounded-xl border border-[#E8E2D9]">
                        <h4 class="font-bold font-serif text-[#544A40] text-sm md:text-base mb-2">1. ご自宅で受けられる</h4>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">教室まで移動せず、ご自宅でマンツーマンレッスンを受けられます。</p>
                    </div>
                    
                    <div class="bg-white p-5 rounded-xl border border-[#E8E2D9]">
                        <h4 class="font-bold font-serif text-[#544A40] text-sm md:text-base mb-2">2. 普段の楽器で確認できる</h4>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">ご自宅のピアノや電子ピアノで受けるため、日々の練習につなげやすくなります。</p>
                    </div>
                    
                    <div class="bg-white p-5 rounded-xl border border-[#E8E2D9]">
                        <h4 class="font-bold font-serif text-[#544A40] text-sm md:text-base mb-2">3. 練習環境も見られる</h4>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">椅子の高さ、楽譜の置き方、音量、練習できる時間帯なども確認できます。</p>
                    </div>
                    
                    <div class="bg-white p-5 rounded-xl border border-[#E8E2D9]">
                        <h4 class="font-bold font-serif text-[#544A40] text-sm md:text-base mb-2">4. スタジオ利用も相談できる</h4>
                        <p class="text-xs text-[#6B5F54] leading-relaxed">ご自宅での受講が難しい場合は、近隣スタジオでのレッスンもご相談可能です。スタジオ利用の場合は、会場費が別途かかります。</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    {/* Section 2: Recommended For */}
    <section class="py-20 bg-[#FCFAF7] border-y border-[#E8E2D9]">
        <div class="max-w-5xl mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-xl md:text-2xl font-serif text-[#544A40] mb-3">出張レッスンが向いている方</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-6 bg-[#A88B58]/30"></div>
                    Recommended For
                    <div class="h-[1px] w-6 bg-[#A88B58]/30"></div>
                </div>
            </div>
            
            <p class="text-sm md:text-base text-[#6B5F54] leading-loose text-center max-w-2xl mx-auto mb-10">
                出張レッスンは、教室へ通う時間を取りにくい方や、ご自宅の楽器でそのまま習いたい方に向いています。
            </p>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm">
                    <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-2 font-serif">01. Busy Parents</span>
                    <h3 class="text-base font-bold text-[#544A40] mb-2 font-serif">子どもの送迎負担を減らしたい方</h3>
                    <p class="text-xs text-[#6B5F54] leading-relaxed">学校・学童・塾の前後に、教室まで移動する負担を減らせます。</p>
                </div>
                
                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm">
                    <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-2 font-serif">02. Consistent Practice</span>
                    <h3 class="text-base font-bold text-[#544A40] mb-2 font-serif">自宅のピアノで習いたい方</h3>
                    <p class="text-xs text-[#6B5F54] leading-relaxed">普段練習している楽器でレッスンするため、家での練習につなげやすくなります。</p>
                </div>
                
                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm">
                    <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-2 font-serif">03. Digital Piano</span>
                    <h3 class="text-base font-bold text-[#544A40] mb-2 font-serif">電子ピアノで始めたい方</h3>
                    <p class="text-xs text-[#6B5F54] leading-relaxed">88鍵盤でタッチによる強弱がつく電子ピアノを推奨しています。</p>
                </div>
                
                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm">
                    <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-2 font-serif">04. Lifelong Learning</span>
                    <h3 class="text-base font-bold text-[#544A40] mb-2 font-serif">大人になってから始めたい方</h3>
                    <p class="text-xs text-[#6B5F54] leading-relaxed">初心者の方、再開したい方、好きな曲を弾きたい方もご相談いただけます。</p>
                </div>
                
                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm">
                    <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-2 font-serif">05. Custom Pace</span>
                    <h3 class="text-base font-bold text-[#544A40] mb-2 font-serif">月1回から相談したい方</h3>
                    <p class="text-xs text-[#6B5F54] leading-relaxed">空き枠やご希望に合わせて、月1回〜ご相談いただけます。</p>
                </div>
                
                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm">
                    <span class="text-[10px] font-bold text-[#A88B58] tracking-widest uppercase block mb-2 font-serif">06. Lesson Environment</span>
                    <h3 class="text-base font-bold text-[#544A40] mb-2 font-serif">自宅の練習環境も見てほしい方</h3>
                    <p class="text-xs text-[#6B5F54] leading-relaxed">椅子の高さ、楽譜の置き方、音量面なども体験時に確認できます。</p>
                </div>
            </div>
        </div>
    </section>

    {/* Section 3: Difference from regular classes */}
    <section class="py-20 bg-white">
        <div class="max-w-5xl mx-auto px-6">
            <div class="text-center mb-12">
                <h2 class="text-xl md:text-2xl font-serif text-[#544A40] mb-3">教室に通うレッスンとの違い</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-6 bg-[#A88B58]/30"></div>
                    Comparison
                    <div class="h-[1px] w-6 bg-[#A88B58]/30"></div>
                </div>
            </div>
            
            <p class="text-sm md:text-base text-[#6B5F54] leading-loose text-center max-w-2xl mx-auto mb-10">
                どちらが絶対に良いということではなく、生活リズムや目的に合わせて選ぶことが大切です。<br />
                出張レッスンには、通うレッスンと比較して次のような特徴があります。
            </p>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                <div class="bg-[#FCFAF7] p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between">
                    <div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-3 border-b border-[#E8E2D9] pb-2 font-serif">1. 移動と送迎</h3>
                        <div class="space-y-2 text-xs leading-relaxed">
                            <p class="text-[#6B5F54]"><span class="font-bold text-[#8C7B6E]">通うレッスン：</span>往復の移動や送迎の付き添いが必要です。</p>
                            <p class="text-[#A88B58] font-medium"><span class="font-bold text-[#A88B58]">出張レッスン：</span>ご自宅で受けられるため、移動や送迎の負担がありません。</p>
                        </div>
                    </div>
                </div>
                
                <div class="bg-[#FCFAF7] p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between">
                    <div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-3 border-b border-[#E8E2D9] pb-2 font-serif">2. 使用する楽器</h3>
                        <div class="space-y-2 text-xs leading-relaxed">
                            <p class="text-[#6B5F54]"><span class="font-bold text-[#8C7B6E]">通うレッスン：</span>教室備え付けのアップライトやグランドピアノを使用します。</p>
                            <p class="text-[#A88B58] font-medium"><span class="font-bold text-[#A88B58]">出張レッスン：</span>普段練習しているご自宅のピアノ・電子ピアノをそのまま使えます。</p>
                        </div>
                    </div>
                </div>

                <div class="bg-[#FCFAF7] p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-between">
                    <div>
                        <h3 class="font-bold text-[#544A40] text-sm md:text-base mb-3 border-b border-[#E8E2D9] pb-2 font-serif">3. 練習環境の確認</h3>
                        <div class="space-y-2 text-xs leading-relaxed">
                            <p class="text-[#6B5F54]"><span class="font-bold text-[#8C7B6E]">通うレッスン：</span>生徒の自宅練習環境を直接確認・調整することは困難です。</p>
                            <p class="text-[#A88B58] font-medium"><span class="font-bold text-[#A88B58]">出張レッスン：</span>椅子の高さ、楽譜の置き方、音量などを直接見て調整できます。</p>
                        </div>
