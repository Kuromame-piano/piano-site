---
import Layout from "../layouts/Layout.astro";
import FeeSystem from "../components/common/FeeSystem.astro";
import InstructorProfile from "../components/common/InstructorProfile.astro";
import { Image } from "astro:assets";
import Breadcrumbs from "../components/common/Breadcrumbs.astro";
import heroPiano from "../assets/images/hero-piano.webp";

const pageTitle = "出張ピアノレッスン｜江東区・中央区周辺｜忙しい大人のための通学不要レッスン";
const pageDescription = "江東区・中央区周辺で大人向けの出張ピアノレッスンを行っています。ご自宅のピアノや電子ピアノで受講でき、対応エリア内は出張費込み。大人の初心者・再開者を中心に、受講頻度や進め方をご相談しながら進めます。";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
        {
            "@type": "BreadcrumbList",
            "itemListElement": [
                {
                    "@type": "ListItem",
                    "position": 1,
                    "name": "Home",
                    "item": "https://playon-music.jp",
                },
                {
                    "@type": "ListItem",
                    "position": 2,
                    "name": "出張ピアノレッスン",
                    "item": "https://playon-music.jp/visit-lesson",
                },
            ],
        },
    ],
});

const instructorIntro = `清澄白河を拠点に、江東区・中央区周辺で大人向けの出張ピアノレッスンを行っています。

大人の初心者・再開者・好きな曲を仕上げたい方を中心に、目的や生活リズムに合わせて進めます。

通学不要で、ご自宅や近隣のレンタルスタジオでリラックスしてピアノを学んでいただけます。

体験レッスンでは、レッスン内容だけでなく、楽器環境や練習時間の確保などについてもお気軽にご相談いただけます。`;

const areas = [
    { name: "清澄白河", slug: "kiyosumi-shirakawa" },
    { name: "門前仲町", slug: "monzen-nakacho" },
    { name: "木場", slug: "kiba" },
    { name: "森下", slug: "morishita" },
    { name: "住吉", slug: "sumiyoshi" },
    { name: "豊洲", slug: "toyosu" },
    { name: "有明", slug: "ariake" },
    { name: "東雲", slug: "shinonome" },
    { name: "月島", slug: "tsukishima" },
    { name: "勝どき", slug: "kachidoki" },
    { name: "晴海", slug: "harumi" },
    { name: "人形町", slug: "ningyocho" },
    { name: "水天宮前", slug: "suitengu-mae" },
    { name: "日本橋浜町", slug: "hamacho" },
];
---

<Layout title={pageTitle} description={pageDescription}>
    <script type="application/ld+json" set:html={schema} slot="head" />

    <!-- Preload Critical Image -->
    <link slot="head" rel="preload" as="image" href={heroPiano.src} />

    <Breadcrumbs
        items={[
            { label: "ホーム", path: "/" },
            { label: "出張ピアノレッスン", path: "/visit-lesson" },
        ]}
    />

    {/* 1. Hero / First View */}
    <div class="relative h-[45vh] md:h-[55vh] flex items-center justify-center overflow-hidden">
        <div class="absolute inset-0 z-0">
            <Image
                src={heroPiano}
                alt="出張ピアノレッスン"
                class="w-full h-full object-cover object-[50%_35%]"
                loading="eager"
            />
            <div class="absolute inset-0 bg-[#3A322B]/35"></div>
        </div>

        <div class="relative z-10 text-center text-white px-4 md:px-6 w-full max-w-4xl mx-auto">
            <h1 class="font-serif tracking-wide">
                <span class="block text-xs sm:text-sm font-bold tracking-[0.2em] mb-4 text-white/90 uppercase">
                    江東区・中央区周辺の出張ピアノレッスン
                </span>

                <span class="flex items-center justify-center gap-4 md:gap-6 text-xs md:text-base mb-8 opacity-90">
                    <span class="h-[1px] w-8 md:w-16 bg-white/60"></span>
                    <span class="tracking-[0.2em] font-light uppercase">Visiting Piano Lesson</span>
                    <span class="h-[1px] w-8 md:w-16 bg-white/60"></span>
                </span>

                <div class="flex items-baseline justify-center gap-0 mb-2 drop-shadow-lg">
                    <span class="text-3xl md:text-5xl lg:text-6xl font-medium tracking-tighter">
                        <span class="inline-block transform hover:scale-105 transition-transform duration-500 cursor-default">髙</span>
                        <span class="inline-block transform hover:scale-105 transition-transform duration-500 delay-75 cursor-default">橋</span>
                        <span class="inline-block transform hover:scale-105 transition-transform duration-500 delay-100 cursor-default">遊</span>
                        <span class="inline-block transform hover:scale-105 transition-transform duration-500 delay-150 cursor-default">月</span>
                    </span>
                    <span class="text-3xl md:text-5xl lg:text-6xl font-medium tracking-tighter opacity-90 drop-shadow-md">
                        ピアノ教室
                    </span>
                </div>
            </h1>

            <div class="mt-10">
                <span class="inline-block px-6 py-2 border border-white/30 rounded-full text-xs md:text-sm tracking-[0.15em] backdrop-blur-sm bg-white/10 text-white/90">
                    出張レッスン専門
                </span>
            </div>
        </div>
    </div>

    {/* Features Overview */}
    <section class="py-16 md:py-20 bg-[#FCFAF7] border-b border-[#E8E2D9]">
        <div class="max-w-5xl mx-auto px-6">
            <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center hover:shadow-md transition-all duration-300">
                    <div class="w-10 h-10 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-3 text-[#A88B58]">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.129-1.125V11.25M3 14.25h16.5M3 14.25v-3.375C3 9.47 4.47 8 6.28 8h11.44c1.81 0 3.28 1.47 3.28 3.28v3.375" />
                        </svg>
                    </div>
                    <h3 class="font-bold text-[#544A40] text-xs sm:text-sm mb-1 font-serif">通学不要</h3>
                    <p class="text-[10px] text-[#6B5F54] leading-relaxed">ご自宅やスタジオで受けられるため、通学の手間や移動時間がかかりません</p>
                </div>

                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center hover:shadow-md transition-all duration-300">
                    <div class="w-10 h-10 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-3 text-[#A88B58]">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                        </svg>
                    </div>
                    <h3 class="font-bold text-[#544A40] text-xs sm:text-sm mb-1 font-serif">出張費込み</h3>
                    <p class="text-[10px] text-[#6B5F54] leading-relaxed">対応エリア内は出張費・交通費込みの料金です</p>
                </div>

                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center hover:shadow-md transition-all duration-300">
                    <div class="w-10 h-10 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-3 text-[#A88B58]">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                        </svg>
                    </div>
                    <h3 class="font-bold text-[#544A40] text-xs sm:text-sm mb-1 font-serif">初心者・再開者対応</h3>
                    <p class="text-[10px] text-[#6B5F54] leading-relaxed">大人の初心者や再開レッスンを主軸にサポートします</p>
                </div>

                <div class="bg-white p-6 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col justify-center items-center text-center hover:shadow-md transition-all duration-300">
                    <div class="w-10 h-10 rounded-full bg-[#FCFAF7] border border-[#E8E2D9] flex items-center justify-center mb-3 text-[#A88B58]">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z" />
                        </svg>
                    </div>
                    <h3 class="font-bold text-[#544A40] text-xs sm:text-sm mb-1 font-serif">無料体験あり</h3>
                    <p class="text-[10px] text-[#6B5F54] leading-relaxed">体験レッスンで、自宅でのレッスンを試せます</p>
                </div>
            </div>
        </div>
    </section>

    {/* Section 2: Characteristics of Visiting Lesson */}
    <section class="py-24 bg-white border-b border-[#E8E2D9]">
        <div class="max-w-5xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-2xl md:text-3xl font-serif text-[#544A40] mb-4">出張ピアノレッスンの特徴</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                    Visiting Lesson
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                </div>
            </div>
            
            <p class="text-sm md:text-base text-[#6B5F54] leading-loose text-center max-w-2xl mx-auto mb-12">
                出張ピアノレッスンは、講師がご自宅または近隣スタジオへ伺い、普段の練習環境に合わせて進めるレッスンです。<br />
                教室へ通うための移動時間や負担をゼロにしながら、無理なく続けやすい形を一緒に考えます。
            </p>

            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
                {/* Card 1 */}
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col items-start transform hover:-translate-y-1 transition-transform duration-300">
                    <div class="w-10 h-10 rounded-full bg-white border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 0 1-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m3 0h1.125c.621 0 1.129-.504 1.129-1.125V11.25M3 14.25h16.5M3 14.25v-3.375C3 9.47 4.47 8 6.28 8h11.44c1.81 0 3.28 1.47 3.28 3.28v3.375" />
                        </svg>
                    </div>
                    <h3 class="text-base md:text-lg font-bold text-[#544A40] mb-3 font-serif">通学の手間と時間をゼロに</h3>
                    <p class="text-xs md:text-sm text-[#6B5F54] leading-relaxed">
                        教室まで通う必要がなく、ご自宅や近隣スタジオでレッスンを受けられます。忙しい仕事や家事の合間にも無理なく続けやすいシステムです。
                    </p>
                </div>
                
                {/* Card 2 */}
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col items-start transform hover:-translate-y-1 transition-transform duration-300">
                    <div class="w-10 h-10 rounded-full bg-white border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M9 9l10.5-3m0 0L21 21M9 9L3 21m6-12V3m12 18H3" />
                        </svg>
                    </div>
                    <h3 class="text-base md:text-lg font-bold text-[#544A40] mb-3 font-serif">普段の楽器で受けられる</h3>
                    <p class="text-xs md:text-sm text-[#6B5F54] leading-relaxed">
                        ご自宅のピアノや電子ピアノでレッスンするため、日々の練習につなげやすくなります。
                    </p>
                </div>
                
                {/* Card 3 */}
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col items-start transform hover:-translate-y-1 transition-transform duration-300">
                    <div class="w-10 h-10 rounded-full bg-white border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M10.125 2.25h3.75a9 9 0 0 1 9 9v3.75a9 9 0 0 1-9 9h-3.75a9 9 0 0 1-9-9v-3.75a9 9 0 0 1 9-9Z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9" />
                        </svg>
                    </div>
                    <h3 class="text-base md:text-lg font-bold text-[#544A40] mb-3 font-serif">練習環境を確認できる</h3>
                    <p class="text-xs md:text-sm text-[#6B5F54] leading-relaxed">
                        椅子の高さ、楽譜の置き方、音量、練習できる時間帯なども体験時に確認できます。
                    </p>
                </div>
                
                {/* Card 4 */}
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col items-start transform hover:-translate-y-1 transition-transform duration-300">
                    <div class="w-10 h-10 rounded-full bg-white border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" />
                        </svg>
                    </div>
                    <h3 class="text-base md:text-lg font-bold text-[#544A40] mb-3 font-serif">大人向け中心の個別サポート</h3>
                    <p class="text-xs md:text-sm text-[#6B5F54] leading-relaxed">
                        大人の初心者・再開者・好きな曲に取り組みたい方を主軸に、目的と生活リズムに合わせた受講方法を一緒に考えます。（お子さまのレッスンもご相談いただけます）
                    </p>
                </div>
                
                {/* Card 5 */}
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col items-start transform hover:-translate-y-1 transition-transform duration-300">
                    <div class="w-10 h-10 rounded-full bg-white border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5" />
                        </svg>
                    </div>
                    <h3 class="text-base md:text-lg font-bold text-[#544A40] mb-3 font-serif">月1回から相談できる</h3>
                    <p class="text-xs md:text-sm text-[#6B5F54] leading-relaxed">
                        空き枠やご希望に合わせて、月1回からの受講もご相談いただけます。
                    </p>
                </div>
                
                {/* Card 6 */}
                <div class="bg-[#FCFAF7] p-8 rounded-2xl border border-[#E8E2D9] shadow-sm flex flex-col items-start transform hover:-translate-y-1 transition-transform duration-300">
                    <div class="w-10 h-10 rounded-full bg-white border border-[#E8E2D9] flex items-center justify-center mb-4 text-[#A88B58]">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-5 h-5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h18v18H3V3Z" />
                        </svg>
                    </div>
                    <h3 class="text-base md:text-lg font-bold text-[#544A40] mb-3 font-serif">スタジオ利用も相談できる</h3>
                    <p class="text-xs md:text-sm text-[#6B5F54] leading-relaxed">
                        ご自宅での受講が難しい場合は、近隣スタジオでのレッスンもご相談可能です。スタジオ利用時は会場費が別途かかります。
                    </p>
                </div>
            </div>
        </div>
    </section>

    {/* Section 3: Common Concerns */}
    <section class="py-24 bg-[#FCFAF7] border-b border-[#E8E2D9]">
        <div class="max-w-4xl mx-auto px-6">
            <div class="text-center mb-16">
                <h2 class="text-2xl md:text-3xl font-serif text-[#544A40] mb-4">自宅レッスンでよくある不安</h2>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase">
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                    Common Concerns
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                </div>
            </div>

            <p class="text-sm md:text-base text-[#6B5F54] leading-loose text-center max-w-2xl mx-auto mb-12">
                出張レッスンを検討するときは、楽器や部屋の広さ、音量、先生を家に呼ぶことへの不安があると思います。<br />
                無料体験では、レッスン内容だけでなく、ご自宅で無理なく受けられるかも確認できます。
            </p>

            <div class="space-y-4 max-w-3xl mx-auto">
                {/* Q1 */}
                <details class="group bg-white rounded-lg shadow-sm border border-[#F1EBE4] overflow-hidden">
                    <summary class="flex items-center justify-between p-6 cursor-pointer list-none hover:bg-[#FCFAF7] transition-colors">
                        <span class="font-medium text-[#544A40] pr-4 text-left text-sm md:text-base">
                            <span class="text-[#A88B58] mr-2 font-serif font-bold">Q.</span>
                            家が広くなくても大丈夫ですか？
                        </span>
                        <span class="flex-shrink-0 w-6 h-6 flex items-center justify-center text-[#A88B58] transition-transform group-open:rotate-180">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                            </svg>
                        </span>
                    </summary>
                    <div class="px-6 pb-6 text-[#544A40]/80 leading-7 border-t border-[#F1EBE4]">
                        <p class="pt-4 pl-7 relative">
                            <span class="text-[#A88B58] font-medium absolute left-0 top-4 font-serif font-bold">A.</span>
