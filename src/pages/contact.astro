---
import Layout from "../layouts/Layout.astro";
import LineButton from "../components/common/LineButton.astro";

const pageTitle = "無料体験レッスン・お問い合わせ | 髙橋遊月ピアノ教室";
const pageDescription =
    "清澄白河発。大人向けの出張ピアノレッスンを行う「髙橋遊月ピアノ教室」の無料体験レッスンお申し込み・お問い合わせページ。ご自宅・近隣スタジオでのレッスンに関するご相談もお気軽にどうぞ。";

const schema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
        {
            "@type": "ListItem",
            position: 1,
            name: "Home",
            item: "https://playon-music.jp",
        },
        {
            "@type": "ListItem",
            position: 2,
            name: "お問い合わせ",
            item: "https://playon-music.jp/contact",
        },
    ],
});
---

<Layout title={pageTitle} description={pageDescription}>
    <script type="application/ld+json" set:html={schema} slot="head" />
    <section class="py-24 bg-[#EAE3DA] min-h-screen">
        <div class="max-w-3xl mx-auto px-6">
            <!-- ページタイトルカード -->
            <div class="bg-white p-12 rounded-[2rem] shadow-2xl border border-[#DCD3C7] mb-8 text-center">
                <h1 class="text-2xl md:text-3xl font-serif mb-2">
                    無料体験レッスン・お問い合わせ
                </h1>
                <div class="flex items-center justify-center gap-4 text-[#A88B58] text-[10px] md:text-xs tracking-[0.2em] font-serif uppercase mb-8">
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                    Contact
                    <div class="h-[1px] w-8 bg-[#A88B58]/30"></div>
                </div>
                <p class="text-sm leading-relaxed max-w-xl mx-auto text-[#544A40]/80">
                    無料体験レッスンのお申し込み・ご相談はこちらから。<br />
                    自宅まで来てもらえるか、電子ピアノでも大丈夫か、曜日や時間だけ相談したいという段階でも大丈夫です。お問い合わせ後、ご希望の方はお電話でのご相談も可能です。
                </p>
            </div>

            <!-- 公式LINEセクション（メイン） -->
            <div class="bg-white p-12 rounded-[2rem] shadow-2xl border border-[#DCD3C7] mb-8">
                <div class="text-center mb-8">
                    <h2 class="text-xl md:text-2xl font-serif text-[#544A40]">
                        公式LINEからのお問い合わせ
                    </h2>
                </div>
                <p class="text-sm text-[#544A40]/80 leading-relaxed text-center mb-8 max-w-xl mx-auto">
                    24時間受付。お名前やご希望の曜日などを簡単にお送りいただくだけで、講師が直接お返事します。曜日や時間のみを確認したい段階でのご相談も承っています。
                </p>
                <div class="text-center mb-10">
                    <LineButton 
                        text="公式LINEで相談する" 
                        className="py-4 px-10 text-base"
                        trackingClass="line_click_contact_top"
                    />
                    <p class="text-xs text-[#6B5F54] mt-3">
                        ※友だち追加後、メッセージを送信してください。
                    </p>
                </div>

                <!-- LINE送信例 -->
                <div class="border-t border-[#E8E2D9] pt-8">
                    <h3 class="text-sm font-bold text-[#544A40] text-center mb-6 font-serif">お問い合わせ例</h3>
                    <div class="grid md:grid-cols-3 gap-6">
                        <!-- カード1: 大人の初心者レッスン相談 -->
                        <div class="bg-[#FCFAF7] p-5 rounded-2xl border border-[#E8E2D9]">
                            <h4 class="text-xs font-bold text-[#A88B58] mb-2 flex items-center gap-1 font-serif">
                                <span class="w-1.5 h-1.5 rounded-full bg-[#A88B58]"></span>
                                大人の初心者レッスン相談
                            </h4>
                            <p class="text-xs text-[#544A40]/80 leading-relaxed font-mono">
                                「初めまして。大人になってから初めてピアノを触るのですが、楽譜が読めなくても体験レッスンは受けられますでしょうか？自宅は豊洲周辺です。」
                            </p>
                        </div>
                        <!-- カード2: 大人の再開レッスン相談 -->
                        <div class="bg-[#FCFAF7] p-5 rounded-2xl border border-[#E8E2D9]">
                            <h4 class="text-xs font-bold text-[#A88B58] mb-2 flex items-center gap-1 font-serif">
                                <span class="w-1.5 h-1.5 rounded-full bg-[#A88B58]"></span>
                                ブランクのある再開相談
                            </h4>
                            <p class="text-xs text-[#544A40]/80 leading-relaxed font-mono">
                                「子どもの頃に数年習っていたのですが、久しぶりに再開したいと思っています。仕事が不定期なため、スケジュールを都度相談しながら月2回ペースでお願いすることは可能でしょうか？」
                            </p>
                        </div>
                        <!-- カード3: 対応エリア・スタジオ相談 -->
                        <div class="bg-[#FCFAF7] p-5 rounded-2xl border border-[#E8E2D9]">
                            <h4 class="text-xs font-bold text-[#A88B58] mb-2 flex items-center gap-1 font-serif">
                                <span class="w-1.5 h-1.5 rounded-full bg-[#A88B58]"></span>
                                スタジオレッスン・その他
                            </h4>
                            <p class="text-xs text-[#544A40]/80 leading-relaxed font-mono">
                                「自宅にピアノがないため、門前仲町駅近くのレンタルスタジオなどでレッスンをお願いすることはできますでしょうか？（子どものレッスンのご相談も含みます。）」
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- メールフォームセクション（サブ） -->
            <div id="mail-form" class="bg-white p-12 rounded-[2rem] shadow-2xl border border-[#DCD3C7] mb-8">
                <div class="text-center mb-8">
                    <h2 class="text-xl md:text-2xl font-serif text-[#544A40]">
                        メールフォームからのお問い合わせ
                    </h2>
                    <p class="text-xs text-[#6B5F54] mt-2">
                        LINEをお使いでない方は、以下のフォームよりお問い合わせください。
                    </p>
                </div>

                <form id="contact-form" class="space-y-8">
                    <input
                        type="hidden"
                        id="source_page"
                        name="source_page"
                        value=""
                    />
                    <input
                        type="hidden"
                        id="source_area"
                        name="source_area"
                        value=""
                    />
                    <div class="grid md:grid-cols-2 gap-8">
                        <div class="space-y-2">
                            <label
                                for="name"
                                class="block text-xs uppercase tracking-widest font-bold text-[#544A40]"
                                >お名前</label
                            >
                            <input
                                type="text"
                                id="name"
                                name="name"
                                required
                                class="w-full border-b border-[#E8E2D9] py-2 focus:border-[#A88B58] outline-none transition-colors bg-transparent placeholder:text-[#DCD3C7] placeholder:font-light"
                                placeholder="山田 佳子"
                            />
                        </div>
                        <div class="space-y-2">
                            <label
                                for="tel"
                                class="block text-xs uppercase tracking-widest font-bold text-[#544A40]"
                                >お電話番号</label
                            >
                            <input
                                type="tel"
                                id="tel"
                                name="tel"
                                class="w-full border-b border-[#E8E2D9] py-2 focus:border-[#A88B58] outline-none transition-colors bg-transparent placeholder:text-[#DCD3C7] placeholder:font-light"
                                placeholder="090-0000-0000"
                            />
                        </div>
                    </div>
                    <div class="space-y-2">
                        <label
                            for="email"
                            class="block text-xs uppercase tracking-widest font-bold text-[#544A40]"
                            >メールアドレス</label
                        >
                        <input
                            type="email"
                            id="email"
                            name="email"
                            required
                            class="w-full border-b border-[#E8E2D9] py-2 focus:border-[#A88B58] outline-none transition-colors bg-transparent placeholder:text-[#DCD3C7] placeholder:font-light"
                            placeholder="example@mail.com"
                        />
                    </div>

                    {/* お問い合わせ内容（ボタン形式） */}
                    <div class="space-y-3">
                        <span
                            class="block text-xs uppercase tracking-widest font-bold text-[#544A40]"
                            >お問い合わせ内容</span
                        >
                        <div class="flex flex-wrap gap-3">
                            <label class="cursor-pointer">
                                <input
                                    type="radio"
                                    name="category"
                                    value="出張体験レッスン"
                                    class="peer sr-only"
                                    checked
                                />
                                <span
                                    class="inline-block px-5 py-3 rounded-full border border-[#E8E2D9] bg-white text-sm text-[#544A40] transition-all hover:bg-[#F7F3EE] peer-checked:bg-[#A88B58] peer-checked:text-white peer-checked:border-[#A88B58] peer-checked:shadow-md"
                                >
                                    出張体験レッスン
                                </span>
                            </label>

                            <label class="cursor-pointer">
                                <input
                                    type="radio"
                                    name="category"
                                    value="オンライン相談"
                                    class="peer sr-only"
                                />
                                <span
                                    class="inline-block px-5 py-3 rounded-full border border-[#E8E2D9] bg-white text-sm text-[#544A40] transition-all hover:bg-[#F7F3EE] peer-checked:bg-[#A88B58] peer-checked:text-white peer-checked:border-[#A88B58] peer-checked:shadow-md"
                                >
                                    オンライン相談
                                </span>
                            </label>

                            <label class="cursor-pointer">
                                <input
                                    type="radio"
                                    name="category"
                                    value="その他・ご質問"
                                    class="peer sr-only"
                                />
                                <span
                                    class="inline-block px-5 py-3 rounded-full border border-[#E8E2D9] bg-white text-sm text-[#544A40] transition-all hover:bg-[#F7F3EE] peer-checked:bg-[#A88B58] peer-checked:text-white peer-checked:border-[#A88B58] peer-checked:shadow-md"
                                >
                                    その他・ご質問
                                </span>
                            </label>
                        </div>
                    </div>

                    <div class="space-y-2">
                        <label
                            for="message"
                            class="block text-xs uppercase tracking-widest font-bold text-[#544A40]"
                            >メッセージ</label
                        >
                        <textarea
                            name="message"
                            id="message"
                            rows="3"
                            class="w-full border-b border-[#E8E2D9] py-2 focus:border-[#A88B58] outline-none transition-colors bg-transparent placeholder:text-[#DCD3C7] placeholder:font-light resize-none"
                            placeholder="レッスンへのご要望やご住所の目安など"
                        ></textarea>
                    </div>
                    <button
                        type="submit"
                        id="submit-btn"
                        class="px-10 bg-[#544A40] text-white py-4 rounded-full font-bold hover:bg-[#3D352E] transition-all shadow-lg tracking-[0.2em] text-sm uppercase mx-auto block"
                    >
                        送信する
                    </button>
                </form>
            </div>
        </div>
    </section>

    <script is:inline>
        const form = document.getElementById("contact-form");
        const btn = document.getElementById("submit-btn");
        const sourcePageInput = document.getElementById("source_page");
        const sourceAreaInput = document.getElementById("source_area");
        // GASウェブアプリURL
        const GAS_URL =
            "https://script.google.com/macros/s/AKfycbwruAuBvHur-ZGDyQcKIPqKCoBRDDhwBPy2a-Y11vH1htI0Yj1dCgg9y4xIqLfK_u7yTQ/exec";

        const params = new URLSearchParams(window.location.search);
        if (sourcePageInput && params.get("from")) {
            sourcePageInput.value = params.get("from");
        }
        if (sourceAreaInput && params.get("area")) {
            sourceAreaInput.value = params.get("area");
        }
        const messageTextarea = document.getElementById("message");
        if (messageTextarea && params.get("message")) {
            messageTextarea.value = params.get("message");
        }

        if (form) {
            form.addEventListener("submit", async (e) => {
                e.preventDefault();
                btn.disabled = true;
                btn.innerText = "Sending...";
                const formData = new FormData(form);
                const data = Object.fromEntries(formData.entries());

                try {
                    await fetch(GAS_URL, {
                        method: "POST",
                        mode: "no-cors",
                        headers: {
                            "Content-Type": "text/plain",
                        },
                        body: JSON.stringify(data),
                    });

                    alert(
                        "お問い合わせありがとうございます。内容を確認し、折り返しご連絡いたします。",
                    );
                    form.reset();
                } catch (error) {
                    console.error("Error:", error);
                    alert("送信中にエラーが発生しました。");
                } finally {
                    btn.disabled = false;
                    btn.innerText = "送信する";
                }
            });
        }
    </script>
</Layout>
