---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
    title: string;
    description?: string;
    image?: string;
    article?: boolean;
    robots?: string;
    keywords?: string | string[];
}

const {
    title,
    description = "江東区・清澄白河で大人のピアノ教室をお探しの方へ。当教室はご自宅や近隣スタジオへ講師が伺う「出張型」の個人ピアノレッスンです。通学の手間や移動時間がかからないため、仕事や家事の合間にリラックスして受講できます。東京音大卒の講師によるマンツーマン指導。",
    image = "/image.png", // デフォルトのOGP画像（プロフィール画像を使用）
    article = false,
    robots = "index, follow", // デフォルトはインデックスさせる
    keywords,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImageURL = new URL(image, Astro.site);
const type = article ? "article" : "website";
const siteName = "髙橋遊月ピアノ教室";

// 検索結果にサイト名を表示するための構造化データ
const websiteSchema = JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: siteName,
    url: Astro.site?.toString() || "https://playon-music.jp",
});
const defaultKeywords =
    "出張ピアノ教室,ピアノレッスン,東京,江東区,中央区,訪問レッスン";

const metaKeywords = keywords
    ? `${Array.isArray(keywords) ? keywords.join(",") : keywords},${defaultKeywords}`
    : defaultKeywords;
---

<!doctype html>
<html lang="ja" class="scroll-smooth">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <meta
            name="google-site-verification"
            content="HYqTs-Lq_YnUb24m9Z0bwUe-lbi5jurfQN_rNtvEkyE"
        />
        <link rel="icon" type="image/png" href="/favicon.png" sizes="192x192" />
        <link rel="icon" href="/favicon.ico" sizes="48x48" />
        <link rel="apple-touch-icon" href="/favicon.png" />
        <meta name="generator" content={Astro.generator} />

        <link rel="canonical" href={canonicalURL} />
        <meta name="robots" content={robots} />
        <link rel="alternate" hreflang="ja" href={canonicalURL.toString()} />
        <link
            rel="alternate"
            hreflang="x-default"
            href={canonicalURL.toString()}
        />

        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="keywords" content={metaKeywords} />

        <meta property="og:type" content={type} />
        <meta property="og:url" content={Astro.url} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={socialImageURL} />
        <meta property="og:site_name" content={siteName} />

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={Astro.url} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        <meta property="twitter:image" content={socialImageURL} />

        {/* サイト名を検索結果に表示するための構造化データ */}
        <script type="application/ld+json" set:html={websiteSchema} />

        {/* プリロード用スロット */}
        <slot name="preload" />

        {/* 各ページから構造化データ等を挿入するためのスロットを追加 */}
        <slot name="head" />
    </head>
    <body class="bg-[#F2EFEA] text-[#544A40] font-sans flex justify-center min-h-screen relative overflow-x-hidden selection:bg-[#A88B58]/30">
        {/* PC用背景装飾：美しいボケ味のある画像やテクスチャを固定配置 */}
        <div class="fixed inset-0 z-[-1] hidden md:block">
            {/* 上品なグラデーションとテクスチャ */}
            <div class="absolute inset-0 bg-gradient-to-br from-[#EAE3DA] to-[#F7F3EE]"></div>
            <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-[#FCFAF7] rounded-full blur-[120px] opacity-60"></div>
            <div class="absolute bottom-[-10%] right-[-10%] w-[60%] h-[60%] bg-[#A88B58] rounded-full blur-[150px] opacity-10"></div>
            {/* 装飾テキスト */}
            <div class="absolute top-1/2 left-[10%] -translate-y-1/2 -rotate-90 opacity-10 font-serif tracking-[0.5em] text-4xl text-[#544A40] whitespace-nowrap pointer-events-none select-none">
                YUZUKI PIANO LESSON
            </div>
        </div>

        {/* スマホ枠コンテナ（最大幅480px、中央配置） */}
        <div class="w-full max-w-[480px] bg-[#FCFAF7] min-h-screen shadow-2xl relative flex flex-col mx-auto overflow-hidden">
            <Header />
            <main class="flex-1 w-full flex flex-col">
                <slot />
            </main>
            <Footer />

            {/* スマホ特化用：画面下部固定のLINEボタン（常に追従） */}
            <div class="fixed bottom-0 w-full max-w-[480px] px-4 pb-6 pt-8 bg-gradient-to-t from-[#FCFAF7] via-[#FCFAF7]/90 to-transparent z-40 pointer-events-none">
                <div class="pointer-events-auto">
                    <a
                        href="https://lin.ee/QL31tIZ"
                        target="_blank"
                        rel="noopener noreferrer"
                        class="flex items-center justify-center bg-[#06C755] text-white py-4 rounded-full font-bold tracking-[0.15em] text-[13px] shadow-lg hover:bg-[#05b04b] transition-all gap-2 line_click_floating"
                    >
                        <svg viewBox="0 0 24 24" class="w-5 h-5 fill-current" xmlns="http://www.w3.org/2000/svg">
                            <path d="M22 10.02c0-4.428-4.486-8.02-10-8.02S2 5.592 2 10.02c0 3.966 3.23 7.284 7.6 7.907.296.064.697.195.797.447.091.229.06.588.029.842-.116.892-.375 2.564-.427 2.9-.06.398.146.365.309.244.152-.113 2.454-1.619 3.456-2.319.721.2 1.488.31 2.236.31 5.514 0 10-3.593 10-8.021z"/>
                        </svg>
                        LINEで無料体験・相談
                    </a>
                </div>
            </div>
        </div>
        {/* GTMの積極的遅延読み込み（ユーザー操作または3秒後に読み込み） */}
        {/* Google Analytics (GA4) */}
        <script
            type="text/javascript"
            async
            src="https://www.googletagmanager.com/gtag/js?id=G-FCM36GL4CP"
        ></script>
        <script type="text/javascript">
            window.dataLayer = window.dataLayer || [];
            function gtag() {
                dataLayer.push(arguments);
            }
            gtag("js", new Date());
            gtag("config", "G-FCM36GL4CP");
        </script>
    </body>
</html>
